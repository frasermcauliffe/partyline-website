---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostMeta from '@/components/blog/PostMeta.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import { APP_LINKS } from '@/data/app-links';
import { cleanBlogText, getPostSlug, type BlogEntry } from '@/lib/blog';
import { blogPostingJsonLd, buildBlogPostSeo } from '@/lib/seo';

interface Props {
	post: BlogEntry;
}

const { post } = Astro.props;
const {
	title,
	description,
	category,
	publishedAt,
	updatedAt,
	author,
	tags,
	featuredImage,
	featuredImageAlt
} = post.data;

const slug = getPostSlug(post);
const cleanDescription = cleanBlogText(description);
const cleanCategory = category ? cleanBlogText(category) : undefined;
const cleanTags = tags.map((tag) => cleanBlogText(tag));
const seo = buildBlogPostSeo({
	title,
	description,
	slug,
	featuredImage
});
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	ogImage={seo.ogImage}
	ogType="article"
	publishedAt={publishedAt}
	updatedAt={updatedAt}
	jsonLd={[blogPostingJsonLd({ post, slug })]}
>
	<article class="blog-post">
		<header class="page-hero page-hero--accent blog-post__hero">
			<div class="container container--narrow">
				<p class="eyebrow">Blog · PartyLine Collective</p>
				<PostMeta
					category={cleanCategory}
					publishedAt={publishedAt}
					updatedAt={updatedAt}
					author={author}
					showUpdated
				/>
				<h1>{title}</h1>
				<p class="lede">{cleanDescription}</p>
			</div>
		</header>

		{
			featuredImage && (
				<div class="container container--narrow blog-post__featured">
					<figure>
						<img
							src={featuredImage}
							alt={featuredImageAlt ?? ''}
							loading="eager"
							decoding="async"
						/>
					</figure>
				</div>
			)
		}

		<div class="container container--narrow blog-post__content">
			<div class="prose">
				<slot />
			</div>

			{
				cleanTags.length > 0 && (
					<footer class="blog-post__tags">
						<p class="blog-post__tags-label">Tags</p>
						<ul class="blog-post__tag-list">
							{cleanTags.map((tag) => (
								<li>
									<span>{tag}</span>
								</li>
							))}
						</ul>
					</footer>
				)
			}
		</div>
	</article>

	<CtaBand
		title="Explore PartyLine"
		description="Join the network — events, profiles and opportunities across Australia’s underground scene."
		primaryLabel="Join PartyLine"
		primaryHref={APP_LINKS.joinSignup}
		secondaryLabel="Explore Events"
		secondaryHref={APP_LINKS.events}
	/>
</BaseLayout>

<style>
	.blog-post__hero h1 {
		font-size: clamp(1.75rem, 6vw, 2.75rem);
		margin-top: var(--space-4);
		overflow-wrap: anywhere;
	}

	.blog-post__featured {
		margin-top: calc(-1 * var(--space-4));
		padding-bottom: var(--space-6);
	}

	.blog-post__featured figure {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		margin: 0;
		overflow: hidden;
	}

	.blog-post__featured img {
		display: block;
		height: auto;
		max-height: min(32rem, 70vh);
		object-fit: cover;
		object-position: top center;
		width: 100%;
	}

	.blog-post__content {
		padding-bottom: clamp(2.5rem, 7vw, 4rem);
	}

	.blog-post__tags {
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-8);
		padding-top: var(--space-5);
	}

	.blog-post__tags-label {
		color: var(--color-muted);
		font-family: var(--font-label);
		font-size: 0.7rem;
		letter-spacing: var(--tracking-label);
		margin-bottom: var(--space-3);
		text-transform: uppercase;
	}

	.blog-post__tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
	}

	.blog-post__tag-list span {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		color: var(--color-muted-strong);
		display: inline-block;
		font-size: 0.85rem;
		padding: 0.35rem 0.75rem;
	}
</style>
