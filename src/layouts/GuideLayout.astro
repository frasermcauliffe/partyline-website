---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import { formatBlogDate, shouldShowUpdatedDate, cleanBlogText, readingTimeLabel } from '@/lib/blog';
import { buildGuideSeo, guideArticleJsonLd } from '@/lib/seo';
import { formatGuideAudience, getGuideSlug, type GuideEntry } from '@/lib/guides';

interface MarkdownHeading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	guide: GuideEntry;
	headings?: MarkdownHeading[];
}

const { guide, headings = [] } = Astro.props;
const {
	title,
	description,
	category,
	audience,
	publishedAt,
	updatedAt,
	relatedLinks,
	seoTitle,
	seoDescription
} = guide.data;

const slug = getGuideSlug(guide);
const cleanDescription = cleanBlogText(description);
const cleanCategory = cleanBlogText(category);
const readTime = readingTimeLabel(guide.body);

const tocHeadings = headings.filter((heading) => heading.depth === 2);
const showToc = tocHeadings.length >= 3;
const seo = buildGuideSeo({
	title,
	description,
	slug,
	seoTitle,
	seoDescription
});
const showUpdateLine = shouldShowUpdatedDate(publishedAt, updatedAt);

const defaultRelatedLinks = [
	{ label: 'All guides', href: '/guides' },
	{ label: 'Events on PartyLine', href: '/events' },
	{ label: 'Opportunities', href: '/opportunities' },
	{ label: 'Platform overview', href: '/platform' },
	{ label: 'Release notes', href: '/releases' }
];

const seenRelatedHrefs = new Set<string>();
const mergedRelatedLinks = [...(relatedLinks ?? []), ...defaultRelatedLinks].filter((link) => {
	if (seenRelatedHrefs.has(link.href)) {
		return false;
	}

	seenRelatedHrefs.add(link.href);
	return true;
});
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	ogType="article"
	publishedAt={publishedAt}
	updatedAt={updatedAt}
	jsonLd={[guideArticleJsonLd({ guide, slug })]}
>
	<article class="guide">
		<header class="page-hero page-hero--accent guide__hero">
			<div class="container container--narrow">
				<p class="eyebrow">Guide · PartyLine Collective</p>
				<div class="guide-meta">
					<span class="guide-meta__category">{cleanCategory}</span>
					<span class="guide-meta__audience">{formatGuideAudience(audience)}</span>
					<time datetime={publishedAt.toISOString()}>{formatBlogDate(publishedAt)}</time>
					{readTime && <span class="guide-meta__readtime">{readTime}</span>}
					{
						showUpdateLine && updatedAt && (
							<span class="guide-meta__updated">
								Updated <time datetime={updatedAt.toISOString()}>{formatBlogDate(updatedAt)}</time>
							</span>
						)
					}
				</div>
				<h1>{title}</h1>
				<p class="lede">{cleanDescription}</p>
			</div>
		</header>

		<div class="container container--narrow guide__content">
			{
				showToc && (
					<nav class="guide__toc" aria-label="On this page">
						<p class="guide__toc-title">On this page</p>
						<ol class="guide__toc-list">
							{tocHeadings.map((heading) => (
								<li>
									<a href={`#${heading.slug}`}>{heading.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)
			}

			<div class="prose">
				<slot />
			</div>

			<RelatedLinks title="Explore PartyLine" links={mergedRelatedLinks} class="guide__related" />
		</div>
	</article>

	<CtaBand
		title="Start with what’s happening now."
		description="Browse public event previews on the website, then open the app for filters, profiles and opportunities across Australia."
		primaryLabel="Browse events"
		primaryHref="/events"
		secondaryLabel="Explore opportunities"
		secondaryHref="/opportunities"
		secondaryExternal={false}
	/>
</BaseLayout>

<style>
	.guide__hero h1 {
		font-size: clamp(1.75rem, 6vw, 2.75rem);
		margin-top: var(--space-4);
		overflow-wrap: anywhere;
	}

	.guide-meta {
		align-items: center;
		color: var(--color-muted);
		display: flex;
		flex-wrap: wrap;
		font-family: var(--font-label);
		font-size: 0.75rem;
		gap: var(--space-2) var(--space-3);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.guide-meta__category {
		color: var(--color-primary);
	}

	.guide-meta__audience {
		font-family: var(--font-body);
		letter-spacing: normal;
		text-transform: none;
	}

	.guide-meta__audience::before,
	.guide-meta__readtime::before,
	.guide-meta__updated::before {
		color: var(--color-border);
		content: '·';
		margin-right: var(--space-3);
	}

	.guide__content {
		padding-bottom: clamp(2.5rem, 7vw, 4rem);
	}

	.guide__toc {
		background: var(--surface-1);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-card);
		margin-bottom: var(--space-6);
		padding: var(--space-5) var(--space-6);
	}

	.guide__toc-title {
		color: var(--color-muted);
		font-family: var(--font-label);
		font-size: var(--text-meta);
		letter-spacing: var(--tracking-label);
		margin-bottom: var(--space-3);
		text-transform: uppercase;
	}

	.guide__toc-list {
		display: grid;
		gap: var(--space-2);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.guide__toc-list a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.guide__toc-list a:hover,
	.guide__toc-list a:focus-visible {
		text-decoration: underline;
	}

	.guide__related {
		margin-top: var(--space-8);
	}
</style>
