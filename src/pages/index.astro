---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import AudienceCard from '@/components/ui/AudienceCard.astro';
import FaqList from '@/components/ui/FaqList.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import GuideCard from '@/components/guides/GuideCard.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicEventPreviewCard from '@/components/previews/PublicEventPreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import SceneIndexTeaser from '@/components/directory/SceneIndexTeaser.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import AppPreviewGrid from '@/components/home/AppPreviewGrid.astro';
import SceneProfilesPanel from '@/components/home/SceneProfilesPanel.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '@/lib/blog';
import { getPublishedGuides } from '@/lib/guides';
import { fetchPublicEvents } from '@/lib/app-api';
import { buildHomeSceneIndexTeaser } from '@/lib/event-directory-stats';
import { getSharedPublicSceneIndex } from '@/lib/event-landing-data';
import { APP_LINKS } from '@/data/app-links';
import {
	HOME_APP_PREVIEWS,
	HOME_EVENTS_LEDE,
	HOME_FAQ,
	HOME_HOW_IT_WORKS,
	HOME_PROFILES_LEDE,
	HOME_ROLE_CARDS,
	HOME_SCENE_PROFILES
} from '@/data/home-content';
import { PAGE_SEO, organizationJsonLd, websiteJsonLd } from '@/lib/seo';

const seo = PAGE_SEO.home;
const latestPosts = getPublishedPosts(await getCollection('blog')).slice(0, 3);
const latestGuides = getPublishedGuides(await getCollection('guides')).slice(0, 3);
const [upcomingEventsResult, sceneIndexResult] = await Promise.all([
	fetchPublicEvents(6),
	getSharedPublicSceneIndex()
]);
const homeSceneIndexTeaser = buildHomeSceneIndexTeaser(sceneIndexResult);
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	jsonLd={[organizationJsonLd(), websiteJsonLd()]}
>
	<HomeHero />

	<section class="home-events-block" aria-label="Find underground events">
		<SectionShell eyebrow="Events" title="Find underground events" lede={HOME_EVENTS_LEDE}>
			<div class="home-events-block__actions">
				<Button href="/events" label="Browse events" variant="primary" />
				<Button
					href={APP_LINKS.events}
					label="Open full calendar in app"
					variant="secondary"
					external
				/>
			</div>
		</SectionShell>

		<SceneIndexTeaser
			stats={homeSceneIndexTeaser.stats}
			showUnavailableCallout={homeSceneIndexTeaser.showUnavailableCallout}
			primaryHref="/events"
			primaryLabel="Browse events"
			secondaryHref={APP_LINKS.events}
			secondaryLabel="Open full calendar in app"
		/>

		<PreviewPanel
			title="Upcoming listings"
			lede="A snapshot of public event listings from the PartyLine app."
			source="app"
			ctaLabel="Browse events"
			ctaHref="/events"
			external={false}
			narrow={false}
		>
			{
				upcomingEventsResult.events.length > 0 ? (
					<div class="home-events-grid">
						{upcomingEventsResult.events.map((event) => (
							<PublicEventPreviewCard event={event} />
						))}
					</div>
				) : (
					<EmptyPreviewState
						ctaHref="/events"
						unavailable={upcomingEventsResult.unavailable}
						message="Browse the event directory on PartyLine or open the app for the full calendar."
						ctaLabel="Browse events"
					/>
				)
			}
		</PreviewPanel>
	</section>

	<SectionShell variant="band" eyebrow="Profiles" title="Browse scene profiles" lede={HOME_PROFILES_LEDE}>
		<SceneProfilesPanel profiles={HOME_SCENE_PROFILES} />
	</SectionShell>

	<SectionShell eyebrow="How it works" title="How PartyLine works">
		<ol class="steps">
			{
				HOME_HOW_IT_WORKS.map((step) => (
					<li>
						<h3>{step.title}</h3>
						<p>{step.description}</p>
					</li>
				))
			}
		</ol>
		<p class="section-link">
			<a href="/how-it-works">Learn how it works &rarr;</a>
		</p>
	</SectionShell>

	<SectionShell variant="feature" eyebrow="Who it's for" title="Built for the whole scene">
		<div class="role-grid">
			{HOME_ROLE_CARDS.map((item) => <AudienceCard {...item} />)}
		</div>
		<p class="section-link">
			<a href="/platform">See everything PartyLine supports &rarr;</a>
		</p>
	</SectionShell>

	<SectionShell
		eyebrow="App preview"
		title="Core app flows"
		lede="A preview of the core PartyLine app flows."
	>
		<AppPreviewGrid items={HOME_APP_PREVIEWS} />
	</SectionShell>

	<SectionShell
		variant="band"
		eyebrow="Guides & stories"
		title="Guides and stories from the scene"
		lede="Practical guides you can return to, plus blog features and culture from Australia\u2019s underground."
	>
		{
			latestGuides.length > 0 && (
				<div class="content-block">
					<div class="content-block__head">
						<h3>Guides</h3>
						<a href="/guides">See all guides &rarr;</a>
					</div>
					<div class="content-grid">
						{latestGuides.map((guide) => (
							<GuideCard guide={guide} />
						))}
					</div>
				</div>
			)
		}

		{
			latestPosts.length > 0 && (
				<div class="content-block">
					<div class="content-block__head">
						<h3>From the blog</h3>
						<a href="/blog">Read the blog &rarr;</a>
					</div>
					<div class="content-grid">
						{latestPosts.map((post) => (
							<BlogCard post={post} />
						))}
					</div>
				</div>
			)
		}
	</SectionShell>

	<SectionShell eyebrow="FAQ" title="Launch questions" lede="Quick answers before you jump into the app.">
		<FaqList items={[...HOME_FAQ]} />
	</SectionShell>

	<section class="home-final-cta">
		<div class="container home-final-cta__inner">
			<div class="home-final-cta__copy">
				<h2>Start with events or profiles.</h2>
				<p>
					Browse underground listings, explore scene profiles, or create your listing when you are
					ready — Perth-first, building across Australia.
				</p>
			</div>
			<div class="home-final-cta__actions">
				<Button href="/events" label="Browse events" variant="primary" />
				<Button href="/profiles" label="Browse profiles" variant="secondary" />
				<Button href={APP_LINKS.createListing} label="Create your profile" variant="secondary" external />
				<Button href={APP_LINKS.submitEvent} label="Submit event" variant="ghost" external />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.home-events-block :global(.section-shell:first-of-type) {
		padding-bottom: 0;
	}

	.home-events-block__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-top: var(--space-5);
	}

	.role-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.steps {
		counter-reset: step;
		display: grid;
		gap: var(--space-4);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.steps li {
		background: var(--surface-1);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-card);
		padding: var(--space-5);
	}

	.steps h3 {
		font-size: var(--text-card-title);
		margin-bottom: var(--space-2);
	}

	.steps p {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.section-link {
		margin-top: var(--space-6);
	}

	.section-link a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.section-link a:hover,
	.section-link a:focus-visible {
		text-decoration: underline;
	}

	.home-events-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.content-block + .content-block {
		margin-top: var(--space-10);
	}

	.content-block__head {
		align-items: baseline;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3) var(--space-5);
		justify-content: space-between;
		margin-bottom: var(--space-5);
	}

	.content-block__head h3 {
		font-size: var(--text-h3);
	}

	.content-block__head a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.content-block__head a:hover,
	.content-block__head a:focus-visible {
		text-decoration: underline;
	}

	.content-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.home-final-cta {
		background: linear-gradient(
			180deg,
			var(--color-surface-soft) 0%,
			rgba(60, 232, 97, 0.06) 100%
		);
		border-block: 1px solid var(--color-border);
		padding-block: clamp(2.5rem, 7vw, 4rem);
	}

	.home-final-cta__inner {
		align-items: center;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		text-align: center;
	}

	.home-final-cta__copy {
		display: grid;
		gap: var(--space-3);
		max-width: 38rem;
	}

	.home-final-cta__copy h2 {
		font-size: clamp(1.5rem, 4vw, 2rem);
	}

	.home-final-cta__copy p {
		color: var(--color-muted-strong);
		line-height: 1.6;
	}

	.home-final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		justify-content: center;
	}

	@media (min-width: 640px) {
		.home-events-grid,
		.content-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.role-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.steps {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.home-final-cta__inner {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}

		.home-final-cta__actions {
			flex-shrink: 0;
			justify-content: flex-end;
		}
	}

	@media (min-width: 1024px) {
		.home-events-grid,
		.content-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.role-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
