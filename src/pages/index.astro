---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import AudienceCard from '@/components/ui/AudienceCard.astro';
import FaqList from '@/components/ui/FaqList.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import Card from '@/components/ui/Card.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LivePreviewSection from '@/components/previews/LivePreviewSection.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '@/lib/blog';
import { fetchPublicEvents } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO, organizationJsonLd, websiteJsonLd } from '@/lib/seo';

const seo = PAGE_SEO.home;
const latestPosts = getPublishedPosts(await getCollection('blog')).slice(0, 3);
const upcomingEventsResult = await fetchPublicEvents(6);

const platformFeatures = [
	{
		title: 'Events',
		description:
			'Discover club nights, warehouse parties, day parties and underground events across Australia — browse live listings in the app.'
	},
	{
		title: 'The Scene profiles',
		description:
			'Public profiles for artists, venues, organisers, production, media and performers — your place in the network.'
	},
	{
		title: 'Opportunities',
		description:
			'DJs wanted, open decks, residencies and more — posted by organisers and venues. Apply with your published profile.'
	},
	{
		title: 'Enquiries & bookings',
		description:
			'Reach out with general enquiries or structured booking requests when you are ready to take things further.'
	},
	{
		title: 'Submit & manage',
		description:
			'Submit events, create listings, review applications, and manage your dashboard, calendar and account settings.'
	},
	{
		title: 'Save & follow',
		description:
			'Save events, follow profiles, and build a personal feed of what matters across the scene.'
	}
];

const audiences = [
	{
		title: 'Fans',
		description: 'Find nights, save events, follow profiles and stay close to what\u2019s happening.',
		ctaLabel: 'Explore Events',
		ctaHref: APP_LINKS.events,
		learnMoreLabel: 'Events on PartyLine',
		learnMoreHref: '/events'
	},
	{
		title: 'Artists & DJs',
		description:
			'Build a public profile, apply to opportunities, and connect with organisers and venues.',
		ctaLabel: 'Create Artist/DJ profile',
		ctaHref: APP_LINKS.createListing,
		learnMoreLabel: 'For Artists & DJs',
		learnMoreHref: '/artists-djs'
	},
	{
		title: 'Organisers',
		description: 'Submit events, post opportunities, and build a visible presence for your crew.',
		ctaLabel: 'Submit an event',
		ctaHref: APP_LINKS.submitEvent,
		learnMoreLabel: 'For Organisers',
		learnMoreHref: '/organisers'
	},
	{
		title: 'Venues',
		description: 'Showcase your space, link events, and connect with the people who fill the room.',
		ctaLabel: 'Add your venue',
		ctaHref: APP_LINKS.createListing,
		learnMoreLabel: 'For Venues',
		learnMoreHref: '/venues'
	},
	{
		title: 'Suppliers & media',
		description:
			'Production, photographers, videographers and performers — be discoverable across the scene.',
		ctaLabel: 'Browse The Scene',
		ctaHref: APP_LINKS.theScene,
		learnMoreLabel: 'About PartyLine',
		learnMoreHref: '/about'
	}
];

const howItWorks = [
	{
		title: 'Join',
		description: 'Create a free PartyLine account — for fans, artists, organisers and venues.'
	},
	{
		title: 'Build presence',
		description: 'Save events, create a listing, or submit your first event depending on your path.'
	},
	{
		title: 'Connect through the scene',
		description: 'Discover, enquire, apply and collaborate across Australia\u2019s underground network.'
	}
];

const exploreCards = [
	{
		title: 'Events',
		description: 'Browse upcoming underground events across Australia.',
		href: APP_LINKS.events
	},
	{
		title: 'The Scene',
		description: 'Search artists, venues, organisers and crews on the network.',
		href: APP_LINKS.theScene
	},
	{
		title: 'Opportunities',
		description: 'Find DJ calls — DJs wanted, open decks, residencies and more.',
		href: APP_LINKS.opportunities
	}
];

const faqItems = [
	{
		question: 'Is PartyLine only for one city?',
		answer:
			'No. PartyLine Collective is built Australia-wide — for events, profiles and scenes across the country.'
	},
	{
		question: 'Is PartyLine a ticketing platform?',
		answer:
			'Not primarily. PartyLine focuses on discovery, profiles and connection. Ticketing stays with organisers via external links where provided.'
	},
	{
		question: 'Who can join?',
		answer:
			'Fans, artists, DJs, organisers, venues, production crews, media and performers. You can join with a simple account or create a public listing.'
	},
	{
		question: 'Does an accepted DJ application mean a confirmed booking?',
		answer:
			'No. Accepted applications are a workflow status in the app — not an automatic confirmed booking. Connection continues from there.'
	},
	{
		question: 'Where is the app?',
		answer:
			'Accounts, events, profiles and dashboards live in the PartyLine app. Use Open the app from any page CTA, or go directly from the header and footer links.'
	}
];
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	jsonLd={[organizationJsonLd(), websiteJsonLd()]}
>
	<section class="hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">PartyLine Collective</p>
			<h1>Find your line into Australia&rsquo;s underground scene.</h1>
			<p class="lede">
				Australia&rsquo;s underground music and events platform — discovery, scene profiles, DJ
				opportunities and practical connection built for the people who make nights happen.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.joinSignup} label="Join PartyLine" variant="primary" external />
				<Button href={APP_LINKS.events} label="Explore Events" variant="secondary" external />
			</div>
		</div>
	</section>

	<Section>
		<SectionHeader
			eyebrow="What it is"
			title="Scene infrastructure for connection"
			lede="PartyLine Collective helps DJs, organisers, venues, suppliers and fans find each other more easily — without replacing your existing relationships. Everything interactive lives in the app."
		/>
		<FeatureGrid items={platformFeatures} columns={3} />
	</Section>

	<LivePreviewSection
		eyebrow="Events"
		title="Upcoming events across Australia"
		lede="A snapshot of public listings in the PartyLine app — open the app for full discovery, filters and details."
		events={upcomingEventsResult.events}
		unavailable={upcomingEventsResult.unavailable}
		ctaHref={APP_LINKS.events}
		ctaLabel="Explore events across Australia"
	/>

	<Section narrow>
		<SectionHeader
			eyebrow="Who it's for"
			title="Built for the people who make nights happen"
		/>
		<div class="audience-grid">
			{audiences.map((item) => <AudienceCard {...item} external />)}
		</div>
	</Section>

	{
		latestPosts.length > 0 && (
			<Section narrow>
				<SectionHeader
					eyebrow="From the blog"
					title="Latest from the blog"
					lede="Track of the Week, Industry Insiiide features, and underground stories from across Australia."
				/>
				<div class="blog-preview-grid">
					{latestPosts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
				<div class="blog-preview-actions">
					<Button href="/blog" label="Read all articles" variant="secondary" />
				</div>
			</Section>
		)
	}

	<Section narrow>
		<SectionHeader eyebrow="How it works" title="Three steps into the network" />
		<ol class="steps">
			{
				howItWorks.map((step) => (
					<li>
						<h3>{step.title}</h3>
						<p>{step.description}</p>
					</li>
				))
			}
		</ol>
		<p class="how-it-works-link">
			<a href="/how-it-works">See the full PartyLine flow →</a>
		</p>
	</Section>

	<Section narrow>
		<SectionHeader
			eyebrow="Why PartyLine"
			title="Built for underground culture"
			lede="Australia-wide, community-first, and practical for a fragmented scene."
		/>
		<ul class="list-check list-check--compact">
			<li>Your relationships stay yours — PartyLine supports connection, not replacement</li>
			<li>Discovery and profiles alongside DJ opportunities and applicant review</li>
			<li>Enquiries and structured booking requests when you want to go further</li>
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader eyebrow="Explore" title="Open the PartyLine app" align="center" />
		<div class="explore-grid">
			{exploreCards.map((card) => <Card {...card} external />)}
		</div>
		<div class="explore-actions">
			<Button href={APP_LINKS.join} label="Open the app" variant="primary" external />
		</div>
	</Section>

	<Section narrow>
		<SectionHeader eyebrow="FAQ" title="Common questions" />
		<FaqList items={faqItems} />
		<p class="faq-app-link">
			<Button href={APP_LINKS.join} label="Open the app" variant="secondary" external />
		</p>
	</Section>

	<CtaBand
		title="Ready to join the network?"
		description="Create your account and start exploring events, profiles and opportunities across Australia."
		primaryLabel="Join PartyLine"
		primaryHref={APP_LINKS.joinSignup}
		secondaryLabel="Explore Events"
		secondaryHref={APP_LINKS.events}
	/>
</BaseLayout>

<style>
	.hero {
		padding-block: clamp(3rem, 10vw, 5.5rem);
	}

	.hero h1 {
		font-size: clamp(2.25rem, 8vw, 3.75rem);
		max-width: 16ch;
	}

	.audience-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.audience-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.audience-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.blog-preview-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
		margin-bottom: var(--space-5);
	}

	@media (min-width: 640px) {
		.blog-preview-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.blog-preview-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.blog-preview-actions {
		display: flex;
		justify-content: center;
	}

	.how-it-works-link {
		margin-top: var(--space-5);
		text-align: center;
	}

	.how-it-works-link a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.how-it-works-link a:hover,
	.how-it-works-link a:focus-visible {
		text-decoration: underline;
	}

	.explore-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
		margin-bottom: var(--space-5);
	}

	@media (min-width: 768px) {
		.explore-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.explore-actions {
		display: flex;
		justify-content: center;
	}

	.faq-app-link {
		display: flex;
		justify-content: center;
		margin-top: var(--space-5);
	}

	.list-check--compact {
		max-width: 40rem;
	}
</style>
