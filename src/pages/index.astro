---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import AudienceCard from '@/components/ui/AudienceCard.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import FaqList from '@/components/ui/FaqList.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import GuideCard from '@/components/guides/GuideCard.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicEventPreviewCard from '@/components/previews/PublicEventPreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import SceneIndexTeaser from '@/components/directory/SceneIndexTeaser.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import AppPreviewGrid from '@/components/home/AppPreviewGrid.astro';
import SceneProfilesPanel from '@/components/home/SceneProfilesPanel.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '@/lib/blog';
import { getPublishedGuides } from '@/lib/guides';
import { fetchPublicEvents } from '@/lib/app-api';
import { buildHomeSceneIndexTeaser } from '@/lib/event-directory-stats';
import { getSharedPublicSceneIndex } from '@/lib/event-landing-data';
import { APP_LINKS } from '@/data/app-links';
import {
	HOME_APP_PREVIEWS,
	HOME_FAQ,
	HOME_FEATURES,
	HOME_HOW_IT_WORKS,
	HOME_ORGANISER_BULLETS,
	HOME_ROLE_CARDS,
	HOME_SCENE_PROFILES
} from '@/data/home-content';
import { PAGE_SEO, organizationJsonLd, websiteJsonLd } from '@/lib/seo';

const seo = PAGE_SEO.home;
const latestPosts = getPublishedPosts(await getCollection('blog')).slice(0, 3);
const latestGuides = getPublishedGuides(await getCollection('guides')).slice(0, 3);
const [upcomingEventsResult, sceneIndexResult] = await Promise.all([
	fetchPublicEvents(6),
	getSharedPublicSceneIndex()
]);
const homeSceneIndexTeaser = buildHomeSceneIndexTeaser(sceneIndexResult);
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	jsonLd={[organizationJsonLd(), websiteJsonLd()]}
>
	<HomeHero />

	<SectionShell eyebrow="Who it's for" title="Built for the whole scene">
		<div class="role-grid">
			{HOME_ROLE_CARDS.map((item) => <AudienceCard {...item} />)}
		</div>
	</SectionShell>

	<SectionShell variant="band" eyebrow="How it works" title="How PartyLine works">
		<ol class="steps">
			{
				HOME_HOW_IT_WORKS.map((step) => (
					<li>
						<h3>{step.title}</h3>
						<p>{step.description}</p>
					</li>
				))
			}
		</ol>
		<p class="section-link">
			<a href="/how-it-works">See the full PartyLine flow &rarr;</a>
		</p>
	</SectionShell>

	<SectionShell
		variant="feature"
		eyebrow="Platform"
		title="What you can do on PartyLine"
		lede="Discovery, profiles, submissions, enquiries and opportunities — scene infrastructure, not a vague landing page."
	>
		<FeatureGrid items={HOME_FEATURES} columns={3} />
		<p class="section-link">
			<a href="/platform">See the full platform overview &rarr;</a>
		</p>
	</SectionShell>

	<SectionShell
		eyebrow="App preview"
		title="See the platform"
		lede="UI preview placeholders for core flows in the PartyLine app. Screenshots can replace these blocks as the marketing site evolves."
	>
		<AppPreviewGrid items={HOME_APP_PREVIEWS} />
	</SectionShell>

	<SceneIndexTeaser
		stats={homeSceneIndexTeaser.stats}
		showUnavailableCallout={homeSceneIndexTeaser.showUnavailableCallout}
		primaryHref="/events"
		primaryLabel="Browse event directory"
		secondaryHref={APP_LINKS.events}
		secondaryLabel="Open the app for the full calendar"
	/>

	<PreviewPanel
		eyebrow="Events"
		title="See what&rsquo;s happening next"
		lede="A snapshot of public event listings in the PartyLine app — Perth-first, building across Australia."
		source="app"
		ctaLabel="Explore all events in the app"
		ctaHref={APP_LINKS.events}
		narrow={false}
	>
		{
			upcomingEventsResult.events.length > 0 ? (
				<div class="home-events-grid">
					{upcomingEventsResult.events.map((event) => (
						<PublicEventPreviewCard event={event} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					ctaHref={APP_LINKS.events}
					unavailable={upcomingEventsResult.unavailable}
					message="See what\u2019s happening next in the PartyLine app."
					ctaLabel="Explore events in the app"
				/>
			)
		}
	</PreviewPanel>

	<SectionShell variant="band" eyebrow="Profiles" title="Scene profiles on PartyLine">
		<SceneProfilesPanel profiles={HOME_SCENE_PROFILES} />
	</SectionShell>

	<SectionShell
		variant="feature"
		eyebrow="Organisers"
		title="For organisers building real events"
		lede="Submit your event, find DJs, request promotion support, track interest, and connect the right people around each show."
	>
		<ul class="list-check">
			{HOME_ORGANISER_BULLETS.map((item) => <li>{item}</li>)}
		</ul>
		<div class="button-row section-actions">
			<Button href={APP_LINKS.submitEvent} label="Submit Event" variant="primary" external />
			<Button href={APP_LINKS.createListing} label="Create Organiser Profile" variant="secondary" external />
			<Button href="/organisers" label="Organiser overview" variant="ghost" />
		</div>
	</SectionShell>

	<SectionShell
		eyebrow="Bookings"
		title="Make bookings more serious with secure deposits"
		lede="Deposits can be paid through PartyLine and held before release, giving both sides a clearer booking record and confirmation path."
	>
		<div class="deposit-grid">
			<PremiumCard variant="status">
				<h3>Held before release</h3>
				<p>
					For supported held-release bookings, recipient payout is released after eligibility checks
					— not as an instant split at payment time.
				</p>
			</PremiumCard>
			<PremiumCard variant="quiet">
				<h3>Clearer booking record</h3>
				<p>
					Enquiries, accepted requests, deposit payment and booking confirmation stay connected inside
					PartyLine rather than scattered across DMs.
				</p>
			</PremiumCard>
		</div>
		<div class="button-row section-actions">
			<Button href={APP_LINKS.createListing} label="Create Profile" variant="primary" external />
			<Button href={APP_LINKS.profiles} label="Browse Profiles" variant="secondary" external />
		</div>
	</SectionShell>

	<SectionShell
		variant="band"
		eyebrow="Guides & stories"
		title="Guides and stories from the scene"
		lede="Practical guides you can return to, plus blog features and culture from Australia\u2019s underground."
	>
		{
			latestGuides.length > 0 && (
				<div class="content-block">
					<div class="content-block__head">
						<h3>Guides</h3>
						<a href="/guides">See all guides &rarr;</a>
					</div>
					<div class="content-grid">
						{latestGuides.map((guide) => (
							<GuideCard guide={guide} />
						))}
					</div>
				</div>
			)
		}

		{
			latestPosts.length > 0 && (
				<div class="content-block">
					<div class="content-block__head">
						<h3>From the blog</h3>
						<a href="/blog">Read the blog &rarr;</a>
					</div>
					<div class="content-grid">
						{latestPosts.map((post) => (
							<BlogCard post={post} />
						))}
					</div>
				</div>
			)
		}
	</SectionShell>

	<SectionShell eyebrow="FAQ" title="Launch questions" lede="Quick answers before you jump into the app.">
		<FaqList items={[...HOME_FAQ]} />
	</SectionShell>

	<section class="home-final-cta">
		<div class="container home-final-cta__inner">
			<div class="home-final-cta__copy">
				<h2>Join the underground network.</h2>
				<p>
					Explore events, create a profile, or submit your next night — Perth-first, building across
					Australia.
				</p>
			</div>
			<div class="home-final-cta__actions">
				<Button href={APP_LINKS.events} label="Explore Events" variant="primary" external />
				<Button href={APP_LINKS.createListing} label="Create Profile" variant="secondary" external />
				<Button href={APP_LINKS.submitEvent} label="Submit Event" variant="secondary" external />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.role-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.steps {
		counter-reset: step;
		display: grid;
		gap: var(--space-4);
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.steps li {
		background: var(--surface-1);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-card);
		padding: var(--space-5);
	}

	.steps h3 {
		font-size: var(--text-card-title);
		margin-bottom: var(--space-2);
	}

	.steps p {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.section-link {
		margin-top: var(--space-6);
	}

	.section-link a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.section-link a:hover,
	.section-link a:focus-visible {
		text-decoration: underline;
	}

	.section-actions {
		margin-top: var(--space-6);
	}

	.home-events-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.list-check {
		color: var(--color-muted);
		display: grid;
		gap: var(--space-3);
		line-height: 1.55;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.list-check li {
		padding-left: 1.35rem;
		position: relative;
	}

	.list-check li::before {
		color: var(--signal);
		content: '\2713';
		left: 0;
		position: absolute;
	}

	.deposit-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.deposit-grid :global(.premium-card h3) {
		font-size: var(--text-card-title);
		margin-bottom: var(--space-2);
	}

	.deposit-grid :global(.premium-card p) {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.content-block + .content-block {
		margin-top: var(--space-10);
	}

	.content-block__head {
		align-items: baseline;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3) var(--space-5);
		justify-content: space-between;
		margin-bottom: var(--space-5);
	}

	.content-block__head h3 {
		font-size: var(--text-h3);
	}

	.content-block__head a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.content-block__head a:hover,
	.content-block__head a:focus-visible {
		text-decoration: underline;
	}

	.content-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.home-final-cta {
		background: linear-gradient(
			180deg,
			var(--color-surface-soft) 0%,
			rgba(60, 232, 97, 0.06) 100%
		);
		border-block: 1px solid var(--color-border);
		padding-block: clamp(2.5rem, 7vw, 4rem);
	}

	.home-final-cta__inner {
		align-items: center;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		text-align: center;
	}

	.home-final-cta__copy {
		display: grid;
		gap: var(--space-3);
		max-width: 38rem;
	}

	.home-final-cta__copy h2 {
		font-size: clamp(1.5rem, 4vw, 2rem);
	}

	.home-final-cta__copy p {
		color: var(--color-muted-strong);
		line-height: 1.6;
	}

	.home-final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		justify-content: center;
	}

	@media (min-width: 640px) {
		.home-events-grid,
		.content-grid,
		.deposit-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.role-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.steps {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.home-final-cta__inner {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}

		.home-final-cta__actions {
			flex-shrink: 0;
			justify-content: flex-end;
		}
	}

	@media (min-width: 1024px) {
		.home-events-grid,
		.content-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.role-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
