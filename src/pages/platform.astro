---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import AudienceCard from '@/components/ui/AudienceCard.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.platform;

const ecosystemLayers = [
	{
		label: 'Layer A',
		title: 'Public website',
		subtitle: 'Discovery, editorial and public previews',
		points: [
			'Events, profile and opportunity previews',
			'Blog, guides and public landing pages',
			'Search-friendly pages for people discovering the scene'
		]
	},
	{
		label: 'Layer B',
		title: 'Web app',
		subtitle: 'Accounts, submissions and private workflows',
		points: [
			'User accounts and public listings',
			'Event submission and management',
			'Dashboards, enquiries, booking requests and feedback'
		]
	},
	{
		label: 'Layer C',
		title: 'Scene activity',
		subtitle: 'The people, places and moments moving through the network',
		points: [
			'Events, venues and organisers',
			'Artists, DJs, performers, media and suppliers',
			'Open calls, opportunities and collaborations'
		]
	},
	{
		label: 'Layer D',
		title: 'Future insights',
		subtitle: 'Roadmap: turning activity into useful scene signals',
		roadmap: true,
		points: [
			'Saves, RSVPs, clicks and profile views',
			'Event performance and discovery signals',
			'What\u2019s On workflows and future scene insights'
		]
	}
];

const audiences = [
	{
		title: 'Fans / guests',
		description:
			'Discover underground events across Australia, save nights that matter, follow profiles and stay close to what\u2019s happening.',
		learnMoreLabel: 'Events on PartyLine',
		learnMoreHref: '/events'
	},
	{
		title: 'Artists / DJs',
		description:
			'Build a public profile, show your sound, apply to opportunities and receive enquiries from organisers and venues.',
		learnMoreLabel: 'For Artists & DJs',
		learnMoreHref: '/artists-djs'
	},
	{
		title: 'Organisers / promoters',
		description:
			'Submit events, post DJ calls and opportunities, review applicants and build a visible presence for your crew.',
		learnMoreLabel: 'For Organisers',
		learnMoreHref: '/organisers'
	},
	{
		title: 'Venues / event spaces',
		description:
			'Showcase your space, link events at your venue and connect with organisers, residents and selectors.',
		learnMoreLabel: 'For Venues',
		learnMoreHref: '/venues'
	},
	{
		title: 'Production / suppliers',
		description:
			'List production crews and suppliers on The Scene so organisers and venues can find the people who make nights work.',
		learnMoreLabel: 'Browse opportunities',
		learnMoreHref: '/opportunities'
	},
	{
		title: 'Media / performers',
		description:
			'Photographers, videographers, performers and media professionals — be discoverable and connect with the underground network.',
		learnMoreLabel: 'Browse opportunities',
		learnMoreHref: '/opportunities'
	}
];

const liveFeatures = [
	'Discover events across Australia — on this website and in the app',
	'Browse public profiles on The Scene',
	'Submit and manage events from the app',
	'Create a public listing or profile',
	'Explore and post opportunities; apply with a published profile',
	'Send enquiries and structured booking requests through profiles',
	'Save events, follow profiles and mark going where supported',
	'Use user and listing dashboards during closed alpha',
	'Submit feedback to help shape the platform'
];

const comingNext = [
	'Stronger booking workflows',
	'Shared calendars',
	'Richer opportunity and application flows',
	'Analytics and scene insight dashboards',
	'City and event guides',
	'Editorial and content workflows such as What\u2019s On'
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Platform · PartyLine Collective</p>
			<h1>One place for Australia&rsquo;s underground music scene to be found, followed and connected.</h1>
			<p class="lede">
				PartyLine connects events, artists, venues, organisers, suppliers and fans — from
				public discovery through profiles, opportunities, enquiries and future scene
				insights.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.join} label="Join PartyLine" variant="primary" external />
				<Button href={APP_LINKS.events} label="Explore Events" variant="secondary" external />
			</div>
		</div>
	</section>

	<Section>
		<SectionHeader
			eyebrow="Ecosystem"
			title="Four layers working together"
			lede="PartyLine is not just a website and not just a directory — it is connected infrastructure for Australia\u2019s underground music and events scene."
		/>
		<ul class="ecosystem-grid">
			{
				ecosystemLayers.map((layer) => (
					<li class="ecosystem-card" class:list={[layer.roadmap && 'ecosystem-card--roadmap']}>
						<p class="ecosystem-card__label">{layer.label}</p>
						<h2>{layer.title}</h2>
						<p class="ecosystem-card__subtitle">{layer.subtitle}</p>
						{layer.roadmap && <p class="ecosystem-card__badge">Coming next — not fully live yet</p>}
						<ul class="list-check list-check--compact">
							{layer.points.map((point) => (
								<li>{point}</li>
							))}
						</ul>
					</li>
				))
			}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader eyebrow="Who it is for" title="Built for the whole underground network" />
		<div class="audience-grid">
			{audiences.map((item) => <AudienceCard {...item} />)}
		</div>
	</Section>

	<Section narrow>
		<SectionHeader
			eyebrow="Available now"
			title="What you can do now"
			lede="PartyLine Collective is in closed alpha — actively tested with a growing invited group. These features are live or near-live today."
		/>
		<ul class="list-check">
			{liveFeatures.map((feature) => <li>{feature}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader eyebrow="Coming next" title="What comes next" />
		<ul class="list-check">
			{comingNext.map((item) => <li>{item}</li>)}
		</ul>
		<p class="roadmap-note">
			Roadmap items are in development — not presented as live features today.
		</p>
	</Section>

	<Section narrow>
		<SectionHeader title="How the website and app work together" />
		<div class="prose">
			<p>
				This website is for public discovery — SEO-friendly landing pages, editorial on the
				<a href="/blog">blog</a>, audience guides and live previews of events, profiles and
				opportunities from the app.
			</p>
			<p>
				The PartyLine app is where accounts, event submission, dashboards, public listings,
				enquiries, booking requests and private workflows live. When you are ready to take
				action, you move from discovery here into the app.
			</p>
			<p>
				Preview cards on this website link into the app for full details. Private dashboards
				and account activity stay inside the app — not indexed on the public web.
			</p>
		</div>
	</Section>

	<Section narrow>
		<SectionHeader title="Related" />
		<ul class="related-links">
			<li><a href="/releases">Release Notes</a></li>
			<li><a href="/how-it-works">How It Works</a></li>
			<li><a href="/about">About PartyLine</a></li>
			<li><a href="/events">Events</a></li>
		</ul>
	</Section>

	<CtaBand
		title="Ready to get on the line?"
		description="Create your account and explore events, profiles and opportunities across Australia."
		primaryLabel="Create an account"
		primaryHref={APP_LINKS.join}
		secondaryLabel="Browse events"
		secondaryHref="/events"
		secondaryExternal={false}
	/>
</BaseLayout>

<style>
	.ecosystem-grid {
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
		list-style: none;
	}

	@media (min-width: 640px) {
		.ecosystem-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.ecosystem-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		display: grid;
		gap: var(--space-3);
		min-width: 0;
		padding: var(--space-6);
	}

	.ecosystem-card--roadmap {
		border-color: rgba(60, 232, 97, 0.25);
	}

	.ecosystem-card__label {
		color: var(--color-primary);
		font-family: var(--font-label);
		font-size: 0.7rem;
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.ecosystem-card h2 {
		font-size: clamp(1.15rem, 3vw, 1.35rem);
	}

	.ecosystem-card__subtitle {
		color: var(--color-muted-strong);
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.ecosystem-card__badge {
		color: var(--color-primary);
		font-family: var(--font-label);
		font-size: 0.7rem;
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.audience-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.audience-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.audience-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.roadmap-note {
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
		margin-top: var(--space-4);
	}

	.related-links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
