---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import StatusBadge from '@/components/ui/StatusBadge.astro';
import StatusCallout from '@/components/ui/StatusCallout.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicOpportunityPreviewCard from '@/components/previews/PublicOpportunityPreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import { fetchPublicOpportunities } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.opportunities;
const opportunitiesResult = await fetchPublicOpportunities(6);

const whoItsFor = [
	{
		title: 'DJs',
		description: 'Selectors looking for open decks, warm-ups, residencies and lineup slots.'
	},
	{
		title: 'Artists',
		description: 'Producers and performers looking for open calls, showcases and community nights.'
	},
	{
		title: 'Organisers',
		description: 'Promoters and crews posting DJs wanted, warm-up needs and lineup calls.'
	},
	{
		title: 'Venues',
		description: 'Spaces looking for residents, regulars or open-deck programming.'
	},
	{
		title: 'Collectives & community crews',
		description: 'Grassroots crews opening lineups and bringing new people into the scene.'
	},
	{
		title: 'Supplier & media',
		description: 'Photographers, videographers and production — opportunity types planned for later.'
	}
];

const opportunityTypes = [
	{
		title: 'DJs wanted',
		description: 'For events, club nights and showcases looking for DJs or artists.'
	},
	{
		title: 'Open decks',
		description: 'For nights giving emerging DJs a chance to play, test sounds or join the lineup.'
	},
	{
		title: 'Warm-up slots',
		description: 'For organisers looking for the right opening or support act.'
	},
	{
		title: 'Residencies',
		description: 'For venues or organisers looking for regular DJs or ongoing music programming.'
	},
	{
		title: 'Guest mixes & submissions',
		description: 'For mixes, tracks, radio-style features, content slots or editorial submissions.'
	},
	{
		title: 'Community showcases',
		description: 'For collectives, labels, student crews or community nights bringing new people in.'
	},
	{
		title: 'Supplier & media calls',
		description:
			'Later-phase calls for photographers, videographers, production, visuals and event support.',
		planned: true
	}
];

const liveNow = [
	'Public opportunities preview on the website',
	'Browse opportunities in the app',
	'Post opportunities where supported',
	'Apply with a published Artist/DJ profile where supported',
	'Organiser dashboard review flows where supported'
];

const comingNext = [
	'Stronger open decks and DJs wanted flows',
	'Better application statuses and communication',
	'Residency-specific flows',
	'More filters by city, date, genre and role',
	'Supplier and media opportunity types',
	'Smarter discovery and recommendations later'
];

const relatedLinks = [
	{ label: 'Platform overview', href: '/platform' },
	{ label: 'For Artists & DJs', href: '/artists-djs' },
	{ label: 'For organisers', href: '/organisers' },
	{ label: 'For venues', href: '/venues' },
	{ label: 'Release notes', href: '/releases' },
	{ label: 'How It Works', href: '/how-it-works' }
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Opportunities · PartyLine Collective</p>
			<h1>Find open calls, DJ slots and ways to get involved in the scene</h1>
			<p class="lede">
				PartyLine opportunities help organisers, venues and collectives post open calls — from
				DJs wanted and open decks to residencies, warm-up slots, guest mixes and future
				supplier or media calls.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.opportunities} label="Browse opportunities" variant="primary" external />
				<Button href={APP_LINKS.postOpportunity} label="Post an opportunity" variant="secondary" external />
			</div>
		</div>
	</section>

	<SectionShell title="What are PartyLine opportunities?">
		<div class="prose">
			<p>
				Opportunities are open calls posted by organisers, venues and collectives — from DJs
				wanted and open decks to residencies, warm-ups, guest mixes and community showcases.
			</p>
			<p>
				They bridge events and people who want to play, support, collaborate, submit or get
				involved. Instead of scattered DMs and reposts, open calls live in one place with
				public discovery on this website and action inside the PartyLine app.
			</p>
		</div>
		<div class="opp-subhead">
			<h2>Who this is for</h2>
		</div>
		<div class="opp-grid opp-grid--2">
			{
				whoItsFor.map((item) => (
					<PremiumCard variant="feature">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell
		variant="band"
		title="Opportunity types"
		lede="Opportunity types depend on what organisers and venues post. Some flows are live in early form during alpha; others will expand as the system develops."
	>
		<div class="opp-grid opp-grid--2">
			{
				opportunityTypes.map((type) => (
					<PremiumCard variant="feature">
						<div class="opp-card__head">
							<h3>{type.title}</h3>
							{type.planned && <StatusBadge status="planned" label="Planned" />}
						</div>
						<p>{type.description}</p>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell title="How to use opportunities">
		<div class="split-grid">
			<div class="split-col">
				<h3>For organisers and venues</h3>
				<ul class="list-check">
					<li>
						Post an open call when you need DJs, residents, open-deck applicants, warm-up acts
						or collaborators.
					</li>
					<li>Connect the opportunity to an event where relevant.</li>
					<li>Review interest from people with published profiles where supported.</li>
					<li>Use opportunities to make calls clearer than scattered DMs.</li>
				</ul>
				<div class="button-row">
					<Button href={APP_LINKS.postOpportunity} label="Post an opportunity" variant="primary" external />
				</div>
			</div>
			<div class="split-col">
				<h3>For DJs and artists</h3>
				<ul class="list-check">
					<li>Browse open calls in the app.</li>
					<li>Apply with a published Artist/DJ profile where supported.</li>
					<li>Use your PartyLine profile to show sound, media, links and event history.</li>
					<li>Follow opportunities that match your city, sound or availability as the product develops.</li>
				</ul>
				<div class="button-row">
					<Button href={APP_LINKS.createListing} label="Create your profile" variant="primary" external />
				</div>
			</div>
		</div>
		<StatusCallout variant="alpha" class="opp-note">
			<p>
				During alpha, flows may still change as the system develops — check the
				<a href="/releases">release notes</a> for what is supported today.
			</p>
		</StatusCallout>
	</SectionShell>

	<PreviewPanel
		eyebrow="Live opportunities"
		title="Open opportunities across Australia"
		lede="DJ calls, open decks, warm-up slots and residencies from the PartyLine app — open the app to apply with your Artist / DJ profile."
		source="app"
		ctaLabel="Browse all opportunities"
		ctaHref={APP_LINKS.opportunities}
		narrow={false}
	>
		<StatusCallout variant="alpha" class="opp-preview-note">
			<p>
				These previews pull from live app data and may look sparse while PartyLine is in closed
				alpha. See <a href="/releases">release notes</a> for current limitations.
			</p>
		</StatusCallout>
		{
			opportunitiesResult.opportunities.length > 0 ? (
				<div class="opp-preview-grid">
					{opportunitiesResult.opportunities.map((opportunity) => (
						<PublicOpportunityPreviewCard opportunity={opportunity} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					message="No public opportunities are available here yet. Browse the app for the latest DJ calls, open decks and residencies."
					ctaHref={APP_LINKS.opportunities}
					ctaLabel="Browse opportunities in the app"
					unavailable={opportunitiesResult.unavailable}
				/>
			)
		}
	</PreviewPanel>

	<SectionShell title="Where opportunities are today">
		<div class="split-grid">
			<StatusCallout variant="success" title="Live now">
				<ul class="list-check list-check--compact">
					{liveNow.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
			<StatusCallout variant="roadmap" title="Coming next">
				<ul class="list-check list-check--compact">
					{comingNext.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
		</div>
		<StatusCallout variant="warning" title="Accepted is not a confirmed booking" class="opp-note">
			<p>
				An accepted opportunity response is the start of a conversation, not a finished
				booking. Final details still need to be confirmed between the people involved.
			</p>
		</StatusCallout>
	</SectionShell>

	<SectionShell variant="editorial" title="How it connects to profiles and events">
		<div class="prose">
			<p>
				Opportunities connect events, organisers, venues and artists. Artist and DJ profiles
				make applications more useful — organisers can see sound, media and activity before
				they respond. Organiser and venue profiles make open calls feel more trustworthy when
				people browse. Event-linked opportunities will become more important as the system
				grows.
			</p>
		</div>
		<RelatedLinks title="Related" links={relatedLinks} layout="inline" class="opp-related" />
	</SectionShell>

	<CtaBand
		title="Post the call, find the fit."
		description="Browse open calls or post an opportunity in the PartyLine app."
		primaryLabel="Browse opportunities"
		primaryHref={APP_LINKS.opportunities}
		secondaryLabel="Post an opportunity"
		secondaryHref={APP_LINKS.postOpportunity}
	/>
</BaseLayout>

<style>
	.prose a {
		color: var(--signal);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.prose a:hover,
	.prose a:focus-visible {
		text-decoration: underline;
	}

	.opp-subhead {
		margin-top: var(--space-8);
		margin-bottom: var(--space-5);
	}

	.opp-subhead h2 {
		font-size: var(--text-h3);
	}

	.opp-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.opp-grid :global(.premium-card h3) {
		font-size: var(--text-card-title);
	}

	.opp-grid :global(.premium-card p) {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.opp-card__head {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		justify-content: space-between;
	}

	@media (min-width: 640px) {
		.opp-grid--2 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.opp-grid--2 {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.split-grid {
		display: grid;
		gap: var(--space-5);
	}

	@media (min-width: 768px) {
		.split-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.split-col h3 {
		font-size: var(--text-card-title);
		margin-bottom: var(--space-4);
	}

	.split-col .button-row {
		margin-top: var(--space-5);
	}

	.opp-note {
		margin-top: var(--space-6);
	}

	.opp-preview-note {
		margin-bottom: var(--space-6);
	}

	.opp-preview-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.opp-preview-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.opp-preview-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.opp-related {
		margin-top: var(--space-8);
	}
</style>
