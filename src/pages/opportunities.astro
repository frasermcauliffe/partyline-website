---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import OpportunityLivePreviewSection from '@/components/previews/OpportunityLivePreviewSection.astro';
import { fetchPublicOpportunities } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.opportunities;
const opportunitiesResult = await fetchPublicOpportunities(6);
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Opportunities · PartyLine Collective</p>
			<h1>DJ calls across the underground scene</h1>
			<p class="lede">
				DJs wanted, open decks, warm-up slots, guest mixes, residencies and community
				showcases — posted by organisers and venues looking for the right fit. Browse and
				apply in the app.
			</p>
			<div class="button-row">
				<Button
					href={APP_LINKS.opportunities}
					label="Browse opportunities"
					variant="primary"
					external
				/>
				<Button
					href={APP_LINKS.postOpportunity}
					label="Post an opportunity"
					variant="secondary"
					external
				/>
			</div>
		</div>
	</section>

	<OpportunityLivePreviewSection
		eyebrow="Live opportunities"
		title="Open opportunities across Australia"
		lede="DJ calls, open decks, warm-up slots and residencies from the PartyLine app — open the app to apply with your Artist / DJ profile."
		opportunities={opportunitiesResult.opportunities}
		unavailable={opportunitiesResult.unavailable}
		emptyMessage="No public opportunities are available here yet. Browse the app for the latest DJ calls, open decks and residencies."
		ctaHref={APP_LINKS.opportunities}
		ctaLabel="Browse all opportunities"
		emptyCtaLabel="Browse opportunities in the app"
	/>

	<Section>
		<SectionHeader
			title="Open calls for DJs"
			lede="Filter by city, type, payment and genre — then apply with a published Artist / DJ profile you own."
		/>
		<ul class="list-check">
			<li>DJs wanted for club nights, showcases and one-off events</li>
			<li>Open decks and warm-up slots for emerging selectors</li>
			<li>Guest mixes and residency opportunities</li>
			<li>Community showcases and scene-led calls</li>
			<li>Organisers review applicants from their dashboard</li>
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Accepted is not a confirmed booking">
			<p>
				When an organiser accepts your application, that&rsquo;s a workflow status — not an
				automatic confirmed booking. PartyLine helps you find each other; the details continue
				from there through enquiries, booking requests or your existing channels.
			</p>
		</Callout>
	</Section>

	<Section>
		<SectionHeader
			title="Posting opportunities"
			lede="Organisers can post from the dashboard or enable &ldquo;Looking for DJs?&rdquo; when submitting an event."
		/>
		<p class="section-note">
			Production, media and performer opportunities may be added later as the platform grows.
			The application system lives in the PartyLine app — this page explains how it works and
			routes you there.
		</p>
		<div class="button-row">
			<Button href={APP_LINKS.postOpportunity} label="Post an opportunity" variant="primary" external />
			<Button
				href={APP_LINKS.createListing}
				label="Create Artist/DJ profile"
				variant="secondary"
				external
			/>
		</div>
	</Section>

	<Section narrow>
		<SectionHeader title="Explore more" lede="Related pages on PartyLine." />
		<ul class="related-links">
			<li><a href="/artists-djs">For Artists &amp; DJs</a></li>
			<li><a href="/organisers">For organisers posting calls</a></li>
			<li><a href="/venues">For venues posting residencies</a></li>
		</ul>
	</Section>

	<CtaBand
		title="Find your next slot"
		description="Browse open calls or post an opportunity in the PartyLine app."
		primaryLabel="Browse opportunities"
		primaryHref={APP_LINKS.opportunities}
		secondaryLabel="Post an opportunity"
		secondaryHref={APP_LINKS.postOpportunity}
	/>
</BaseLayout>

<style>
	.section-note {
		color: var(--color-muted-strong);
		line-height: 1.65;
		margin-bottom: var(--space-5);
		max-width: 42rem;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
