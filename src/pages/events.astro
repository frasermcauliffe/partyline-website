---
import EventDirectoryPage from '@/components/directory/EventDirectoryPage.astro';
import { fetchPublicEvents, fetchPublicSceneIndex } from '@/lib/app-api';
import {
	buildDirectoryStatsFromSceneIndex,
	buildSceneSnapshotFromSceneIndex,
	buildTrackedEventFormats
} from '@/lib/event-directory-stats';
import {
	directoryPageJsonLd,
	faqPageJsonLd,
	organizationJsonLd,
	PAGE_SEO,
	websiteJsonLd
} from '@/lib/seo';
import { DIRECTORY_FAQ } from '@/data/directory-content';

const seo = PAGE_SEO.events;
const [eventsResult, sceneResult] = await Promise.all([
	fetchPublicEvents(24),
	fetchPublicSceneIndex()
]);
const events = eventsResult.events;
const stats = buildDirectoryStatsFromSceneIndex(sceneResult, eventsResult);
const trackedFormats = buildTrackedEventFormats(sceneResult);
const sceneSnapshot = buildSceneSnapshotFromSceneIndex(sceneResult, eventsResult);

const jsonLd = [
	organizationJsonLd(),
	websiteJsonLd(),
	directoryPageJsonLd({
		description: seo.description,
		events: events.map((event) => ({ title: event.title, appUrl: event.appUrl }))
	}),
	faqPageJsonLd([...DIRECTORY_FAQ])
];
---

<EventDirectoryPage
	seo={seo}
	jsonLd={jsonLd}
	events={events}
	eventsUnavailable={eventsResult.unavailable}
	stats={stats}
	trackedFormats={trackedFormats}
	sceneSnapshot={sceneSnapshot}
	sceneResult={sceneResult}
/>
