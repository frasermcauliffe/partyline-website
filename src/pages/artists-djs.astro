---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import StatusBadge from '@/components/ui/StatusBadge.astro';
import StatusCallout from '@/components/ui/StatusCallout.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicProfilePreviewCard from '@/components/previews/PublicProfilePreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.artistsDjs;
const artistProfilesResult = await fetchPublicListings('artist_dj', 6);

const whoItsFor = [
	{
		title: 'DJs',
		description: 'Club, warehouse and festival selectors building a public presence across Australia.'
	},
	{
		title: 'Producers',
		description: 'Electronic producers who want organisers and venues to hear their sound and see their work.'
	},
	{
		title: 'Live artists',
		description: 'Live electronic and hybrid performers connecting with underground events and crews.'
	},
	{
		title: 'Selectors & performers',
		description: 'Artists building a discoverable scene profile — not locked to one city or one promo channel.'
	}
];

const liveNow = [
	'Create a public Artist/DJ listing on The Scene',
	'Add bio, genres, mixes, media and social links',
	'Get found when organisers and venues browse the network',
	'Connect your profile to events and opportunities',
	'Apply to open opportunities where posted',
	'Receive enquiries and structured booking requests through your profile',
	'Manage profile and activity from your dashboard'
];

const comingNext = [
	'Richer open decks and DJs wanted flows',
	'Stronger application UX',
	'Profile analytics',
	'Deeper event linkage'
];

const whyCreate = [
	'One place to show your sound, links and scene activity',
	'Easier for organisers and venues to understand fit before reaching out',
	'Built to connect with opportunities, event links and future analytics'
];

const connections = [
	{
		title: 'Events',
		description: 'Link your profile to the nights you play across Australia.',
		href: '/events'
	},
	{
		title: 'Opportunities',
		description: 'Apply to open calls, open decks, warm-ups and residencies.',
		href: '/opportunities'
	},
	{
		title: 'Platform',
		description: 'See how profiles connect across the wider PartyLine network.',
		href: '/platform'
	}
];

const relatedLinks = [
	{ label: 'Events', href: '/events' },
	{ label: 'Opportunities', href: '/opportunities' },
	{ label: 'Guides', href: '/guides' },
	{ label: 'Platform overview', href: '/platform' }
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Artists &amp; DJs · PartyLine Collective</p>
			<h1>Get discovered across the underground scene</h1>
			<p class="lede">
				Create a public Artist or DJ profile, show your sound and activity, apply to
				opportunities where posted, and connect with organisers and venues across
				Australia&rsquo;s underground network.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.createListing} label="Create your profile" variant="primary" external />
				<Button href={APP_LINKS.opportunities} label="Explore opportunities" variant="secondary" external />
			</div>
		</div>
	</section>

	<SectionShell eyebrow="Audience" title="Who this is for">
		<div class="role-grid">
			{
				whoItsFor.map((item) => (
					<PremiumCard variant="feature">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell variant="band" title="Where artists & DJs are today">
		<div class="split-grid">
			<StatusCallout variant="success" title="What you can do now">
				<ul class="list-check list-check--compact">
					{liveNow.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
			<StatusCallout variant="roadmap" title="Coming next">
				<div class="callout-badge"><StatusBadge status="planned" label="Planned" /></div>
				<ul class="list-check list-check--compact">
					{comingNext.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
		</div>
	</SectionShell>

	<SectionShell variant="editorial" title="How it connects to the wider platform">
		<div class="connection-grid">
			{
				connections.map((item) => (
					<PremiumCard variant="quiet" href={item.href}>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
						<span class="connection-link">Learn more &rarr;</span>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<PreviewPanel
		eyebrow="Live profiles"
		title="Artists and DJs across Australia"
		lede="Public Artist and DJ profiles from the PartyLine app — open the app for full bios, mixes, media and opportunities."
		source="app"
		ctaLabel="Explore all artists and DJs"
		ctaHref={APP_LINKS.artists}
		narrow={false}
	>
		<StatusCallout variant="alpha" class="preview-note">
			<p>
				These previews pull from live app data and may look sparse while PartyLine is in closed
				alpha. See <a href="/releases">release notes</a> for current limitations.
			</p>
		</StatusCallout>
		{
			artistProfilesResult.listings.length > 0 ? (
				<div class="profile-grid">
					{artistProfilesResult.listings.map((profile) => (
						<PublicProfilePreviewCard profile={profile} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					message="No public Artist/DJ profiles are available here yet. Explore The Scene in the app."
					ctaHref={APP_LINKS.artists}
					ctaLabel="Explore artists and DJs in the app"
					unavailable={artistProfilesResult.unavailable}
				/>
			)
		}
	</PreviewPanel>

	<SectionShell title="Why create a PartyLine profile?">
		<ul class="list-check">
			{whyCreate.map((item) => <li>{item}</li>)}
		</ul>
	</SectionShell>

	<SectionShell narrow>
		<StatusCallout variant="warning" title="Applying to opportunities">
			<p>
				You need a published Artist / DJ profile to apply. Browse open calls in the app, submit
				your application, and track status on the opportunity page. Accepted does not
				automatically mean a confirmed booking — it&rsquo;s the start of the conversation.
			</p>
		</StatusCallout>
		<RelatedLinks title="Related" links={relatedLinks} layout="inline" class="role-related" />
	</SectionShell>

	<CtaBand
		title="Build your profile"
		description="Create your Artist or DJ listing in the app and start connecting with organisers, venues and the wider scene."
		primaryLabel="Create your profile"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Explore opportunities"
		secondaryHref={APP_LINKS.opportunities}
	/>
</BaseLayout>

<style>
	.role-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.connection-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.role-grid :global(.premium-card h3),
	.connection-grid :global(.premium-card h3) {
		font-size: var(--text-card-title);
	}

	.role-grid :global(.premium-card p),
	.connection-grid :global(.premium-card p) {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.connection-link {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
	}

	.split-grid {
		display: grid;
		gap: var(--space-5);
	}

	.callout-badge {
		margin-bottom: var(--space-4);
	}

	.profile-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.preview-note {
		margin-bottom: var(--space-6);
	}

	.preview-note :global(a) {
		color: var(--signal);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.preview-note :global(a:hover),
	.preview-note :global(a:focus-visible) {
		text-decoration: underline;
	}

	.role-related {
		margin-top: var(--space-8);
	}

	@media (min-width: 640px) {
		.role-grid,
		.profile-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.split-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 960px) {
		.connection-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.role-grid,
		.profile-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
