---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import ProfileLivePreviewSection from '@/components/previews/ProfileLivePreviewSection.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.artistsDjs;
const artistProfilesResult = await fetchPublicListings('artist_dj', 6);

const whoItsFor = [
	{
		title: 'DJs',
		description: 'Club, warehouse and festival selectors building a public presence across Australia.'
	},
	{
		title: 'Producers',
		description: 'Electronic producers who want organisers and venues to hear their sound and see their work.'
	},
	{
		title: 'Live artists',
		description: 'Live electronic and hybrid performers connecting with underground events and crews.'
	},
	{
		title: 'Selectors & performers',
		description: 'Artists building a discoverable scene profile — not locked to one city or one promo channel.'
	}
];

const liveNow = [
	'Create a public Artist/DJ listing on The Scene',
	'Add bio, genres, mixes, media and social links',
	'Get found when organisers and venues browse the network',
	'Connect your profile to events and opportunities',
	'Apply to open opportunities where posted',
	'Receive enquiries and structured booking requests through your profile',
	'Manage profile and activity from your dashboard'
];

const comingNext = [
	'Richer open decks and DJs wanted flows',
	'Stronger application UX',
	'Profile analytics',
	'Deeper event linkage'
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Artists &amp; DJs · PartyLine Collective</p>
			<h1>Get discovered across the underground scene</h1>
			<p class="lede">
				Create a public Artist or DJ profile, show your sound and activity, apply to
				opportunities where posted, and connect with organisers and venues across
				Australia&rsquo;s underground network.
			</p>
			<div class="button-row">
				<Button
					href={APP_LINKS.createListing}
					label="Create your profile"
					variant="primary"
					external
				/>
				<Button
					href={APP_LINKS.opportunities}
					label="Explore opportunities"
					variant="secondary"
					external
				/>
			</div>
		</div>
	</section>

	<Section narrow>
		<SectionHeader eyebrow="Audience" title="Who this is for" />
		<FeatureGrid items={whoItsFor} columns={2} />
	</Section>

	<Section narrow>
		<SectionHeader title="What you can do now" />
		<ul class="list-check">
			{liveNow.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="How it connects to the wider platform" />
		<div class="prose">
			<p>
				Your profile connects to events, opportunities and future booking workflows on
				PartyLine. This website gives public visibility through previews and landing pages;
				the app handles profile management, enquiries and private activity.
			</p>
			<p>
				<a href="/platform">See the full PartyLine platform overview →</a>
			</p>
		</div>
	</Section>

	<Section narrow>
		<p class="preview-note">
			These previews pull from live app data and may look sparse while PartyLine is in closed
			alpha. See <a href="/releases">release notes</a> for current limitations.
		</p>
		<ProfileLivePreviewSection
			eyebrow="Live profiles"
			title="Artists and DJs across Australia"
			lede="Public Artist and DJ profiles from the PartyLine app — open the app for full bios, mixes, media and opportunities."
			profiles={artistProfilesResult.listings}
			unavailable={artistProfilesResult.unavailable}
			emptyMessage="No public Artist/DJ profiles are available here yet. Explore The Scene in the app."
			ctaHref={APP_LINKS.artists}
			ctaLabel="Explore all artists and DJs"
		/>
	</Section>

	<Section narrow>
		<SectionHeader title="Why create a PartyLine profile?" />
		<ul class="list-check">
			<li>One place to show your sound, links and scene activity</li>
			<li>Easier for organisers and venues to understand fit before reaching out</li>
			<li>Built to connect with opportunities, event links and future analytics</li>
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Applying to opportunities">
			<p>
				You need a published Artist / DJ profile to apply. Browse open calls in the app,
				submit your application, and track status on the opportunity page. Accepted does not
				automatically mean a confirmed booking — it&rsquo;s the start of the conversation.
			</p>
		</Callout>
	</Section>

	<Section narrow>
		<SectionHeader title="Coming next" />
		<ul class="list-check list-check--compact">
			{comingNext.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="Related" />
		<ul class="related-links">
			<li><a href="/platform">Platform overview</a></li>
			<li><a href="/how-it-works">How It Works</a></li>
			<li><a href="/releases">Release notes</a></li>
			<li><a href="/opportunities">DJ opportunities</a></li>
			<li><a href="/organisers">For organisers</a></li>
			<li><a href="/venues">For venues</a></li>
			<li>
				<a href={APP_LINKS.artists} target="_blank" rel="noopener noreferrer">
					Explore Artists &amp; DJs in the app
				</a>
			</li>
		</ul>
	</Section>

	<CtaBand
		title="Build your profile"
		description="Create your Artist or DJ listing in the app and start connecting with organisers, venues and the wider scene."
		primaryLabel="Create your profile"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Explore opportunities"
		secondaryHref={APP_LINKS.opportunities}
	/>
</BaseLayout>

<style>
	.prose a {
		color: var(--color-primary);
		font-weight: 600;
		text-decoration: none;
	}

	.prose a:hover,
	.prose a:focus-visible {
		text-decoration: underline;
	}

	.preview-note {
		color: var(--color-muted-strong);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: var(--space-5);
		max-width: 42rem;
	}

	.preview-note a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.preview-note a:hover,
	.preview-note a:focus-visible {
		text-decoration: underline;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
