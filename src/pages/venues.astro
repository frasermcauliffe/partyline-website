---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import ProfileLivePreviewSection from '@/components/previews/ProfileLivePreviewSection.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.venues;
const venueProfilesResult = await fetchPublicListings('venue', 6);

const whoItsFor = [
	{
		title: 'Clubs & bars',
		description: 'Regular underground nights and resident programming across Australia.'
	},
	{
		title: 'Warehouses & industrial spaces',
		description: 'Alternative rooms built for bass, community and one-off takeovers.'
	},
	{
		title: 'Creative spaces',
		description: 'Multi-use studios, galleries and flexible rooms that host scene-led events.'
	},
	{
		title: 'Independent venues',
		description: 'Any space that hosts underground events and wants clearer discovery on the network.'
	}
];

const liveNow = [
	'List your space on The Scene',
	'Show location, capacity, facilities, setup and vibe',
	'Link events hosted at the venue',
	'Help organisers judge fit before they reach out',
	'Connect with organisers, artists, production and media',
	'Receive enquiries and structured booking requests through your profile',
	'Post or support opportunities such as residencies or open decks where relevant'
];

const venueProfileShows = [
	'Space type and capacity',
	'Location and access notes',
	'Facilities, sound, lighting and setup',
	'Photos, media and collaboration notes',
	'Hosted and linked events',
	'Enquiry path through your public profile'
];

const comingNext = [
	'Richer venue tooling',
	'Calendars and event-linked dashboards',
	'Stronger enquiry and booking workflows',
	'Scene insights in a later phase'
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Venues · PartyLine Collective</p>
			<h1>Showcase your space on the network</h1>
			<p class="lede">
				List your club, warehouse or event space on The Scene, link the nights you host, and
				help organisers and artists understand your room before they reach out — across
				Australia&rsquo;s underground scene.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.createListing} label="List your venue" variant="primary" external />
				<Button href={APP_LINKS.opportunities} label="Explore opportunities" variant="secondary" external />
			</div>
		</div>
	</section>

	<Section narrow>
		<SectionHeader eyebrow="Audience" title="Who this is for" />
		<FeatureGrid items={whoItsFor} columns={2} />
	</Section>

	<Section narrow>
		<SectionHeader title="What you can do now" />
		<ul class="list-check">
			{liveNow.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="How it connects to the wider platform" />
		<div class="prose">
			<p>
				Venue profiles make the physical scene easier to discover. Events can link back to
				your space, and organisers and artists can understand capacity, setup and vibe before
				making enquiries.
			</p>
			<p>
				<a href="/platform">See the full PartyLine platform overview →</a>
			</p>
		</div>
	</Section>

	<Section narrow>
		<p class="preview-note">
			These previews pull from live app data and may look sparse while PartyLine is in closed
			alpha. See <a href="/releases">release notes</a> for current limitations.
		</p>
		<ProfileLivePreviewSection
			eyebrow="Live profiles"
			title="Venues across Australia"
			lede="Public venue profiles from the PartyLine app — open the app for capacity, facilities, events and full details."
			profiles={venueProfilesResult.listings}
			unavailable={venueProfilesResult.unavailable}
			emptyMessage="No public venue profiles are available here yet. Explore venues in the app."
			ctaHref={APP_LINKS.venues}
			ctaLabel="Explore all venues"
		/>
	</Section>

	<Section narrow>
		<SectionHeader title="What your venue profile can show" />
		<ul class="list-check">
			{venueProfileShows.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Your space, your relationships">
			<p>
				Venues are central to underground culture. PartyLine Collective helps your space be
				discoverable alongside the events and people that move through it — supporting
				connection without sitting in the middle of your regular partnerships.
			</p>
		</Callout>
	</Section>

	<Section narrow>
		<SectionHeader title="Coming next" />
		<ul class="list-check list-check--compact">
			{comingNext.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="Related" />
		<ul class="related-links">
			<li><a href="/platform">Platform overview</a></li>
			<li><a href="/how-it-works">How It Works</a></li>
			<li><a href="/releases">Release notes</a></li>
			<li><a href="/organisers">For organisers</a></li>
			<li><a href="/artists-djs">For artists and DJs</a></li>
			<li><a href="/opportunities">Post a residency or open decks opportunity</a></li>
			<li>
				<a href={APP_LINKS.venues} target="_blank" rel="noopener noreferrer">
					Explore venues in the app
				</a>
			</li>
		</ul>
	</Section>

	<CtaBand
		title="List your venue"
		description="Create your venue profile in the app and connect with organisers and artists across Australia."
		primaryLabel="List your venue"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Explore opportunities"
		secondaryHref={APP_LINKS.opportunities}
	/>
</BaseLayout>

<style>
	.prose a {
		color: var(--color-primary);
		font-weight: 600;
		text-decoration: none;
	}

	.prose a:hover,
	.prose a:focus-visible {
		text-decoration: underline;
	}

	.preview-note {
		color: var(--color-muted-strong);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: var(--space-5);
		max-width: 42rem;
	}

	.preview-note a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.preview-note a:hover,
	.preview-note a:focus-visible {
		text-decoration: underline;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
