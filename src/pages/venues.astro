---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import StatusBadge from '@/components/ui/StatusBadge.astro';
import StatusCallout from '@/components/ui/StatusCallout.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicProfilePreviewCard from '@/components/previews/PublicProfilePreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.venues;
const venueProfilesResult = await fetchPublicListings('venue', 6);

const whoItsFor = [
	{
		title: 'Clubs & bars',
		description: 'Regular underground nights and resident programming across Australia.'
	},
	{
		title: 'Warehouses & industrial spaces',
		description: 'Alternative rooms built for bass, community and one-off takeovers.'
	},
	{
		title: 'Creative spaces',
		description: 'Multi-use studios, galleries and flexible rooms that host scene-led events.'
	},
	{
		title: 'Independent venues',
		description: 'Any space that hosts underground events and wants clearer discovery on the network.'
	}
];

const liveNow = [
	'List your space on The Scene',
	'Show location, capacity, facilities, setup and vibe',
	'Link events hosted at the venue',
	'Help organisers judge fit before they reach out',
	'Connect with organisers, artists, production and media',
	'Receive enquiries and structured booking requests through your profile',
	'Post or support opportunities such as residencies or open decks where relevant'
];

const venueProfileShows = [
	'Space type and capacity',
	'Location and access notes',
	'Facilities, sound, lighting and setup',
	'Photos, media and collaboration notes',
	'Hosted and linked events',
	'Enquiry path through your public profile'
];

const comingNext = [
	'Richer venue tooling',
	'Calendars and event-linked dashboards',
	'Stronger enquiry and booking workflows',
	'Scene insights in a later phase'
];

const connections = [
	{
		title: 'Events',
		description: 'Link the nights your space hosts and help people find them.',
		href: '/events'
	},
	{
		title: 'Organisers',
		description: 'Connect with the promoters and crews who program your room.',
		href: '/organisers'
	},
	{
		title: 'Suppliers & production',
		description: 'Find production, media and suppliers across The Scene.',
		href: APP_LINKS.theScene,
		external: true
	}
];

const relatedLinks = [
	{ label: 'Events', href: '/events' },
	{ label: 'For organisers', href: '/organisers' },
	{ label: 'Platform overview', href: '/platform' },
	{ label: 'Contact PartyLine', href: '/contact' }
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Venues · PartyLine Collective</p>
			<h1>Showcase your space on the network</h1>
			<p class="lede">
				List your club, warehouse or event space on The Scene, link the nights you host, and
				help organisers and artists understand your room before they reach out — across
				Australia&rsquo;s underground scene.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.createListing} label="List your venue" variant="primary" external />
				<Button href="/events" label="Explore events" variant="secondary" />
			</div>
		</div>
	</section>

	<SectionShell eyebrow="Audience" title="Who this is for">
		<div class="role-grid">
			{
				whoItsFor.map((item) => (
					<PremiumCard variant="feature">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell variant="band" title="Where venues are today">
		<div class="split-grid">
			<StatusCallout variant="success" title="What you can do now">
				<ul class="list-check list-check--compact">
					{liveNow.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
			<StatusCallout variant="roadmap" title="Coming next">
				<div class="callout-badge"><StatusBadge status="planned" label="Planned" /></div>
				<ul class="list-check list-check--compact">
					{comingNext.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
		</div>
	</SectionShell>

	<SectionShell variant="editorial" title="How it connects to the wider platform">
		<div class="connection-grid">
			{
				connections.map((item) => (
					<PremiumCard variant="quiet" href={item.href} external={item.external}>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
						<span class="connection-link">Learn more &rarr;</span>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<PreviewPanel
		eyebrow="Live profiles"
		title="Venues across Australia"
		lede="Public venue profiles from the PartyLine app — open the app for capacity, facilities, events and full details."
		source="app"
		ctaLabel="Explore all venues"
		ctaHref={APP_LINKS.venues}
		narrow={false}
	>
		<StatusCallout variant="alpha" class="preview-note">
			<p>
				These previews pull from live app data and may look sparse while PartyLine is in closed
				alpha. See <a href="/releases">release notes</a> for current limitations.
			</p>
		</StatusCallout>
		{
			venueProfilesResult.listings.length > 0 ? (
				<div class="profile-grid">
					{venueProfilesResult.listings.map((profile) => (
						<PublicProfilePreviewCard profile={profile} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					message="No public venue profiles are available here yet. Explore venues in the app."
					ctaHref={APP_LINKS.venues}
					ctaLabel="Explore venues in the app"
					unavailable={venueProfilesResult.unavailable}
				/>
			)
		}
	</PreviewPanel>

	<SectionShell title="What your venue profile can show">
		<div class="value-grid">
			{
				venueProfileShows.map((item) => (
					<PremiumCard variant="feature">
						<h3>{item}</h3>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell narrow>
		<StatusCallout variant="info" title="Your space, your relationships">
			<p>
				Venues are central to underground culture. PartyLine Collective helps your space be
				discoverable alongside the events and people that move through it — supporting
				connection without sitting in the middle of your regular partnerships.
			</p>
		</StatusCallout>
		<RelatedLinks title="Related" links={relatedLinks} layout="inline" class="role-related" />
	</SectionShell>

	<CtaBand
		title="List your venue"
		description="Create your venue profile in the app and connect with organisers and artists across Australia."
		primaryLabel="List your venue"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Explore events"
		secondaryHref="/events"
		secondaryExternal={false}
	/>
</BaseLayout>

<style>
	.role-grid,
	.connection-grid,
	.value-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.role-grid :global(.premium-card h3),
	.connection-grid :global(.premium-card h3),
	.value-grid :global(.premium-card h3) {
		font-size: var(--text-card-title);
	}

	.role-grid :global(.premium-card p),
	.connection-grid :global(.premium-card p) {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.connection-link {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
	}

	.split-grid {
		display: grid;
		gap: var(--space-5);
	}

	.callout-badge {
		margin-bottom: var(--space-4);
	}

	.profile-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.preview-note {
		margin-bottom: var(--space-6);
	}

	.preview-note :global(a) {
		color: var(--signal);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.preview-note :global(a:hover),
	.preview-note :global(a:focus-visible) {
		text-decoration: underline;
	}

	.role-related {
		margin-top: var(--space-8);
	}

	@media (min-width: 640px) {
		.role-grid,
		.value-grid,
		.profile-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.split-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 960px) {
		.connection-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.role-grid,
		.value-grid,
		.profile-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
