---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.venues;
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Venues · PartyLine Collective</p>
			<h1>Showcase your space on the network</h1>
			<p class="lede">
				Create a venue or event space profile, connect with organisers and artists, receive
				hire and booking enquiries, and link events hosted at your space.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.createListing} label="Add your venue" variant="primary" external />
				<Button href={APP_LINKS.venues} label="Explore venues" variant="secondary" external />
			</div>
		</div>
	</section>

	<Section>
		<SectionHeader
			title="Your venue on The Scene"
			lede="Clubs, warehouses, bars and alternative spaces — discoverable alongside the events and people that move through them."
		/>
		<ul class="list-check">
			<li>Public profiles for clubs, warehouses, bars and alternative event spaces</li>
			<li>Show location, capacity, facilities and collaboration notes on your profile</li>
			<li>Floorplans and deeper venue tooling may come later as the platform grows</li>
			<li>Connect with organisers, artists, production and media on the scene</li>
			<li>Receive enquiries and structured booking requests</li>
			<li>Link to events happening at your venue and promote recurring nights</li>
			<li>Find resident DJs and open decks through <a href="/opportunities">opportunities</a></li>
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Your space, your relationships">
			<p>
				Venues are central to underground culture. PartyLine Collective helps your space be
				discoverable alongside the events and people that move through it — without
				inserting itself between you and your regular partners.
			</p>
		</Callout>
	</Section>

	<Section narrow>
		<SectionHeader title="Explore more" lede="Related pages and directories in the PartyLine app." />
		<ul class="related-links">
			<li><a href="/organisers">For organisers listing events at your venue</a></li>
			<li><a href="/artists-djs">For artists and DJs</a></li>
			<li><a href="/opportunities">Post a residency or open decks opportunity</a></li>
			<li>
				<a href={APP_LINKS.venues} target="_blank" rel="noopener noreferrer">
					Explore venues in the app
				</a>
			</li>
		</ul>
	</Section>

	<CtaBand
		title="List your venue"
		description="Create your venue profile in the app and connect with organisers and artists across Australia."
		primaryLabel="Add your venue"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Post an opportunity"
		secondaryHref={APP_LINKS.postOpportunity}
	/>
</BaseLayout>

<style>
	.list-check a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.list-check a:hover,
	.list-check a:focus-visible {
		text-decoration: underline;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
