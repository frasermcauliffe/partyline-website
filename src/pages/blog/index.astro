---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import EmptyState from '@/components/ui/EmptyState.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '@/lib/blog';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.blog;
const allPosts = await getCollection('blog');
const posts = getPublishedPosts(allPosts);

const relatedLinks = [
	{ label: 'Guides', href: '/guides' },
	{ label: 'Events', href: '/events' },
	{ label: 'Opportunities', href: '/opportunities' },
	{ label: 'Platform overview', href: '/platform' }
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Blog · PartyLine Collective</p>
			<h1>Articles &amp; updates</h1>
			<p class="lede">
				Track of the Week, Industry Insiiide features, and stories from Australia&rsquo;s
				underground music and events scene.
			</p>
		</div>
	</section>

	<SectionShell variant="editorial" eyebrow="Why the blog" title="Stories and culture from the scene">
		<div class="prose">
			<p>
				The PartyLine blog is where the scene speaks — artist features, Industry Insiiide
				interviews, Track of the Week and stories from the people building underground music
				and events across Australia.
			</p>
			<p>
				Looking for practical how-tos instead? The <a href="/guides">guides</a> cover discovery,
				event submissions, opportunities, profiles and bookings — steps you can return to when
				you need them.
			</p>
		</div>
	</SectionShell>

	<SectionShell>
		{
			posts.length === 0 ? (
				<EmptyState
					variant="no-data"
					title="No articles yet"
					message="No articles published yet. Check back soon."
				/>
			) : (
				<div class="blog-grid">
					{posts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			)
		}
	</SectionShell>

	<SectionShell narrow>
		<RelatedLinks title="Explore more" links={relatedLinks} layout="inline" />
	</SectionShell>

	<CtaBand
		title="Start with what’s happening now."
		description="Browse public event previews on the website, then open the app for filters, profiles and opportunities across Australia."
		primaryLabel="Browse events"
		primaryHref="/events"
		secondaryLabel="Explore opportunities"
		secondaryHref="/opportunities"
		external={false}
	/>
</BaseLayout>

<style>
	.prose a {
		color: var(--color-primary);
		font-weight: 600;
		text-decoration: none;
	}

	.prose a:hover,
	.prose a:focus-visible {
		text-decoration: underline;
	}

	.blog-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.blog-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.blog-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
