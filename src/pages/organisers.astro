---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import ProfileLivePreviewSection from '@/components/previews/ProfileLivePreviewSection.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.organisers;
const organiserProfilesResult = await fetchPublicListings('organiser', 6);

const whoItsFor = [
	{
		title: 'Promoters & collectives',
		description: 'Crews putting on club nights, warehouses and community events across Australia.'
	},
	{
		title: 'Event coordinators',
		description: 'People managing lineups, venues, promo and production for underground nights.'
	},
	{
		title: 'Labels & brands',
		description: 'Collectives building a visible presence around a sound, series or community.'
	},
	{
		title: 'Community crews',
		description: 'Student, grassroots and venue-run teams hosting scene-led events.'
	}
];

const liveNow = [
	'Submit club nights, warehouses, showcases and community events',
	'Build a public organiser or collective profile on The Scene',
	'Link events to venues, artists and organisers where available',
	'Add names manually where profiles do not exist yet',
	'Post DJ opportunities from your dashboard or when submitting an event',
	'Review applicants where supported — viewed, shortlist, accept or request more info',
	'Track basic engagement signals where available, such as saves, going responses and ticket link clicks',
	'Request tracked ticket or partner links through the partners flow where appropriate'
];

const organiserPresence = [
	'One public home for your organiser or collective identity',
	'Event listings linked to venues, lineups and profiles',
	'Opportunity posting for DJs wanted, open decks and residencies',
	'Dashboard workflows for applications and event management',
	'Future collaborator access as the platform grows'
];

const comingNext = [
	'Stronger event dashboards',
	'Shared calendars',
	'Collaborator access for crews and partners',
	'Richer analytics and reporting',
	'What\u2019s On and content workflow improvements'
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Organisers · PartyLine Collective</p>
			<h1>Put your events and crew on the radar</h1>
			<p class="lede">
				Submit events, build your organiser presence, post DJ opportunities, review
				applicants where supported, and help people across Australia find your nights —
				practical tools for promoters, collectives and event crews.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.submitEvent} label="Submit an event" variant="primary" external />
				<Button
					href={APP_LINKS.postOpportunity}
					label="Post an opportunity"
					variant="secondary"
					external
				/>
			</div>
		</div>
	</section>

	<Section narrow>
		<SectionHeader eyebrow="Audience" title="Who this is for" />
		<FeatureGrid items={whoItsFor} columns={2} />
	</Section>

	<Section narrow>
		<SectionHeader title="What you can do now" />
		<ul class="list-check">
			{liveNow.map((item) => <li>{item}</li>)}
			<li>
				Learn more about <a href="/partners">ticket partnerships</a> where a tracked link makes
				sense for your events.
			</li>
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="How it connects to the wider platform" />
		<div class="prose">
			<p>
				Organiser profiles connect events, venues, lineups and opportunities on PartyLine.
				This website helps your nights get discovered through previews and landing pages; the
				app supports submissions, dashboards and private workflows.
			</p>
			<p>
				<a href="/platform">See the full PartyLine platform overview →</a>
			</p>
		</div>
	</Section>

	<Section narrow>
		<p class="preview-note">
			These previews pull from live app data and may look sparse while PartyLine is in closed
			alpha. See <a href="/releases">release notes</a> for current limitations.
		</p>
		<ProfileLivePreviewSection
			eyebrow="Live profiles"
			title="Organisers across Australia"
			lede="Public organiser and collective profiles from the PartyLine app — open the app for full bios, linked events and opportunities."
			profiles={organiserProfilesResult.listings}
			unavailable={organiserProfilesResult.unavailable}
			emptyMessage="No public organiser profiles are available here yet. Explore organisers in the app."
			ctaHref={APP_LINKS.organisers}
			ctaLabel="Explore all organisers"
		/>
	</Section>

	<Section narrow>
		<SectionHeader title="Submit events and build your organiser presence" />
		<ul class="list-check">
			{organiserPresence.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Your stack, your relationships">
			<p>
				PartyLine Collective supports discovery and connection — it doesn&rsquo;t replace
				your ticketing, your promo channels or the relationships you&rsquo;ve built. Use
				external ticket links, keep your existing connections, and let PartyLine help new
				people find you.
			</p>
		</Callout>
	</Section>

	<Section narrow>
		<SectionHeader title="Coming next" />
		<ul class="list-check list-check--compact">
			{comingNext.map((item) => <li>{item}</li>)}
		</ul>
	</Section>

	<Section narrow>
		<SectionHeader title="Related" />
		<ul class="related-links">
			<li><a href="/platform">Platform overview</a></li>
			<li><a href="/how-it-works">How It Works</a></li>
			<li><a href="/releases">Release notes</a></li>
			<li><a href="/events">Event discovery</a></li>
			<li><a href="/opportunities">DJ opportunities</a></li>
			<li><a href="/partners">Ticket partnerships</a></li>
			<li>
				<a href={APP_LINKS.organisers} target="_blank" rel="noopener noreferrer">
					Explore organisers in the app
				</a>
			</li>
		</ul>
	</Section>

	<CtaBand
		title="Start listing your events"
		description="Submit your first event or create an organiser profile in the PartyLine app."
		primaryLabel="Submit an event"
		primaryHref={APP_LINKS.submitEvent}
		secondaryLabel="Create organiser profile"
		secondaryHref={APP_LINKS.createListing}
	/>
</BaseLayout>

<style>
	.prose a {
		color: var(--color-primary);
		font-weight: 600;
		text-decoration: none;
	}

	.prose a:hover,
	.prose a:focus-visible {
		text-decoration: underline;
	}

	.list-check a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.list-check a:hover,
	.list-check a:focus-visible {
		text-decoration: underline;
	}

	.preview-note {
		color: var(--color-muted-strong);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: var(--space-5);
		max-width: 42rem;
	}

	.preview-note a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.preview-note a:hover,
	.preview-note a:focus-visible {
		text-decoration: underline;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
