---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Callout from '@/components/ui/Callout.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.organisers;
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Organisers · PartyLine Collective</p>
			<h1>Put your events and crew on the radar</h1>
			<p class="lede">
				Submit events, build your organiser presence, post DJ opportunities, review
				applicants, and track engagement signals from your event dashboard — practical tools
				for promoters, collectives and event crews.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.submitEvent} label="Submit an event" variant="primary" external />
				<Button
					href={APP_LINKS.postOpportunity}
					label="Post an opportunity"
					variant="secondary"
					external
				/>
			</div>
		</div>
	</section>

	<Section>
		<SectionHeader
			title="Tools for promoters and crews"
			lede="List events, link profiles, review DJ applications, and track basic engagement — all in the PartyLine app."
		/>
		<ul class="list-check">
			<li>Submit club nights, day parties, warehouses, showcases and community events</li>
			<li>Link venue, organiser and lineup profiles — or add names manually</li>
			<li>Upload posters, gallery images and media embeds</li>
			<li>Track engagement signals such as saves, RSVPs and ticket link clicks where available</li>
			<li>Post DJ opportunities from your dashboard or when submitting an event</li>
			<li>Review applications — mark viewed, shortlist, accept or request more info</li>
			<li>Build a visible organiser profile on The Scene</li>
			<li>Request a tracked PartyLine ticket link or affiliate setup via our <a href="/partners">ticket partnerships</a> page</li>
		</ul>
	</Section>

	<Section narrow>
		<Callout title="Your stack, your relationships">
			<p>
				PartyLine Collective supports discovery and connection — it doesn&rsquo;t replace
				your ticketing, your promo channels or the relationships you&rsquo;ve built. Use
				external ticket links, keep your existing connections, and let PartyLine help new
				people find you.
			</p>
		</Callout>
	</Section>

	<Section narrow>
		<SectionHeader title="Explore more" lede="Related pages and directories in the PartyLine app." />
		<ul class="related-links">
			<li><a href="/events">Event discovery on PartyLine</a></li>
			<li><a href="/opportunities">DJ opportunities</a></li>
			<li><a href="/partners">Ticket partnerships</a></li>
			<li>
				<a href={APP_LINKS.organisers} target="_blank" rel="noopener noreferrer">
					Explore organisers in the app
				</a>
			</li>
		</ul>
	</Section>

	<CtaBand
		title="Start listing your events"
		description="Submit your first event or create an organiser profile in the PartyLine app."
		primaryLabel="Submit an event"
		primaryHref={APP_LINKS.submitEvent}
		secondaryLabel="Create organiser profile"
		secondaryHref={APP_LINKS.createListing}
	/>
</BaseLayout>

<style>
	.list-check a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.list-check a:hover,
	.list-check a:focus-visible {
		text-decoration: underline;
	}

	.related-links {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links a {
		color: var(--color-primary);
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
	}

	.related-links a:hover,
	.related-links a:focus-visible {
		text-decoration: underline;
	}
</style>
