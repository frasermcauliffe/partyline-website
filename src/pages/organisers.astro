---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import StatusBadge from '@/components/ui/StatusBadge.astro';
import StatusCallout from '@/components/ui/StatusCallout.astro';
import RelatedLinks from '@/components/ui/RelatedLinks.astro';
import CtaBand from '@/components/ui/CtaBand.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicProfilePreviewCard from '@/components/previews/PublicProfilePreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import { fetchPublicListings } from '@/lib/app-api';
import { APP_LINKS } from '@/data/app-links';
import { PAGE_SEO } from '@/lib/seo';

const seo = PAGE_SEO.organisers;
const organiserProfilesResult = await fetchPublicListings('organiser', 6);

const whoItsFor = [
	{
		title: 'Promoters & collectives',
		description: 'Crews putting on club nights, warehouses and community events across Australia.'
	},
	{
		title: 'Event coordinators',
		description: 'People managing lineups, venues, promo and production for underground nights.'
	},
	{
		title: 'Labels & brands',
		description: 'Collectives building a visible presence around a sound, series or community.'
	},
	{
		title: 'Community crews',
		description: 'Student, grassroots and venue-run teams hosting scene-led events.'
	}
];

const liveNow = [
	'Submit club nights, warehouses, showcases and community events',
	'Build a public organiser or collective profile in the profiles directory',
	'Link events to venues, artists and organisers where available',
	'Add names manually where profiles do not exist yet',
	'Post DJ opportunities from your dashboard or when submitting an event',
	'Review applicants where supported — viewed, shortlist, accept or request more info',
	'Track basic engagement signals where available, such as saves, going responses and ticket link clicks'
];

const organiserPresence = [
	'One public home for your organiser or collective identity',
	'Event listings linked to venues, lineups and profiles',
	'Opportunity posting for DJs wanted, open decks and residencies',
	'Dashboard workflows for applications and event management',
	'Future collaborator access as the platform grows'
];

const comingNext = [
	'Stronger event dashboards',
	'Shared calendars',
	'Collaborator access for crews and partners',
	'Richer analytics and reporting',
	'What\u2019s On and content workflow improvements'
];

const connections = [
	{
		title: 'Events',
		description: 'Submit and link the nights you run across Australia.',
		href: '/events'
	},
	{
		title: 'Opportunities',
		description: 'Post DJs wanted, open decks, warm-ups and residencies.',
		href: '/opportunities'
	},
	{
		title: 'Venues',
		description: 'Connect your events to the spaces that host them.',
		href: '/venues'
	}
];

const relatedLinks = [
	{ label: 'Events', href: '/events' },
	{ label: 'Opportunities', href: '/opportunities' },
	{ label: 'Guides', href: '/guides' },
	{ label: 'Platform overview', href: '/platform' }
];
---

<BaseLayout title={seo.title} description={seo.description} canonicalPath={seo.canonicalPath}>
	<section class="page-hero page-hero--accent">
		<div class="container">
			<p class="eyebrow">Organisers · PartyLine Collective</p>
			<h1>Put your events and crew on the radar</h1>
			<p class="lede">
				Submit events, build your organiser presence, post DJ opportunities, review applicants
				where supported, and help people across Australia find your nights — practical tools
				for promoters, collectives and event crews.
			</p>
			<div class="button-row">
				<Button href={APP_LINKS.submitEvent} label="Submit an event" variant="primary" external />
				<Button href={APP_LINKS.postOpportunity} label="Post an opportunity" variant="secondary" external />
			</div>
		</div>
	</section>

	<SectionShell eyebrow="Audience" title="Who this is for">
		<div class="role-grid">
			{
				whoItsFor.map((item) => (
					<PremiumCard variant="feature">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<SectionShell variant="band" title="Where organisers are today">
		<div class="split-grid">
			<StatusCallout variant="success" title="What you can do now">
				<ul class="list-check list-check--compact">
					{liveNow.map((item) => <li>{item}</li>)}
					<li>
						Request tracked ticket or partner links through the
						<a href="/partners">partners flow</a> where appropriate
					</li>
				</ul>
			</StatusCallout>
			<StatusCallout variant="roadmap" title="Coming next">
				<div class="callout-badge"><StatusBadge status="planned" label="Planned" /></div>
				<ul class="list-check list-check--compact">
					{comingNext.map((item) => <li>{item}</li>)}
				</ul>
			</StatusCallout>
		</div>
	</SectionShell>

	<SectionShell variant="editorial" title="How it connects to the wider platform">
		<div class="connection-grid">
			{
				connections.map((item) => (
					<PremiumCard variant="quiet" href={item.href}>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
						<span class="connection-link">Learn more &rarr;</span>
					</PremiumCard>
				))
			}
		</div>
	</SectionShell>

	<PreviewPanel
		eyebrow="Live profiles"
		title="Organisers across Australia"
		lede="Public organiser and collective profiles from the PartyLine app — open the app for full bios, linked events and opportunities."
		source="app"
		ctaLabel="Explore all organisers"
		ctaHref={APP_LINKS.organisers}
		narrow={false}
	>
		<StatusCallout variant="alpha" class="preview-note">
			<p>
				These previews pull from live app data and may look sparse while PartyLine is in closed
				alpha. See <a href="/releases">release notes</a> for current limitations.
			</p>
		</StatusCallout>
		{
			organiserProfilesResult.listings.length > 0 ? (
				<div class="profile-grid">
					{organiserProfilesResult.listings.map((profile) => (
						<PublicProfilePreviewCard profile={profile} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					message="No public organiser profiles are available here yet. Explore organisers in the app."
					ctaHref={APP_LINKS.organisers}
					ctaLabel="Explore organisers in the app"
					unavailable={organiserProfilesResult.unavailable}
				/>
			)
		}
	</PreviewPanel>

	<SectionShell title="Submit events and build your organiser presence">
		<ul class="list-check">
			{organiserPresence.map((item) => <li>{item}</li>)}
		</ul>
	</SectionShell>

	<SectionShell narrow>
		<StatusCallout variant="info" title="Your stack, your relationships">
			<p>
				PartyLine Collective supports discovery and connection — it doesn&rsquo;t replace your
				ticketing, your promo channels or the relationships you&rsquo;ve built. Use external
				ticket links, keep your existing connections, and let PartyLine help new people find you.
			</p>
		</StatusCallout>
		<RelatedLinks title="Related" links={relatedLinks} layout="inline" class="role-related" />
	</SectionShell>

	<CtaBand
		title="Start listing your events"
		description="Create an organiser profile or submit your first event in the PartyLine app."
		primaryLabel="Create organiser profile"
		primaryHref={APP_LINKS.createListing}
		secondaryLabel="Submit an event"
		secondaryHref={APP_LINKS.submitEvent}
	/>
</BaseLayout>

<style>
	.role-grid,
	.connection-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.role-grid :global(.premium-card h3),
	.connection-grid :global(.premium-card h3) {
		font-size: var(--text-card-title);
	}

	.role-grid :global(.premium-card p),
	.connection-grid :global(.premium-card p) {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.connection-link {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
	}

	.split-grid {
		display: grid;
		gap: var(--space-5);
	}

	.split-grid :global(a) {
		color: var(--signal);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.split-grid :global(a:hover),
	.split-grid :global(a:focus-visible) {
		text-decoration: underline;
	}

	.callout-badge {
		margin-bottom: var(--space-4);
	}

	.profile-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.preview-note {
		margin-bottom: var(--space-6);
	}

	.preview-note :global(a) {
		color: var(--signal);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.preview-note :global(a:hover),
	.preview-note :global(a:focus-visible) {
		text-decoration: underline;
	}

	.role-related {
		margin-top: var(--space-8);
	}

	@media (min-width: 640px) {
		.role-grid,
		.profile-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.split-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 960px) {
		.connection-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.role-grid,
		.profile-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
