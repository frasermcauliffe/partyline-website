---
import EventLandingPage from '@/components/directory/EventLandingPage.astro';
import {
	GENRE_LANDING_PAGES,
	getLandingBreadcrumbs,
	getLandingCanonicalPath
} from '@/data/event-landing-pages';
import { getSharedPublicEvents, getSharedPublicSceneIndex } from '@/lib/event-landing-data';
import { buildLandingSceneStats, filterEventsByGenreConfig } from '@/lib/event-directory-stats';
import {
	breadcrumbJsonLd,
	buildPageSeo,
	collectionLandingPageJsonLd,
	faqPageJsonLd,
	organizationJsonLd,
	websiteJsonLd
} from '@/lib/seo';

export async function getStaticPaths() {
	const [eventsResult, sceneResult] = await Promise.all([
		getSharedPublicEvents(),
		getSharedPublicSceneIndex()
	]);
	const { events, unavailable } = eventsResult;

	return GENRE_LANDING_PAGES.map((page) => {
		const filteredEvents = filterEventsByGenreConfig(
			events,
			page.matchGenres,
			page.matchEventType
		);

		const sceneStats = buildLandingSceneStats({
			kind: 'genre',
			label: page.h1.replace(' Events on PartyLine', '').replace(' Events', ''),
			sceneResult,
			matchGenres: page.matchGenres
		});

		const canonicalPath = getLandingCanonicalPath(page);
		const seo = buildPageSeo({
			title: page.seoTitle,
			description: page.seoDescription,
			canonicalPath
		});

		return {
			params: { slug: page.slug },
			props: {
				page,
				events: filteredEvents,
				unavailable,
				sceneStats,
				seo,
				canonicalPath,
				jsonLd: [
					organizationJsonLd(),
					websiteJsonLd(),
					collectionLandingPageJsonLd({
						name: page.h1,
						description: page.seoDescription,
						url: canonicalPath,
						events: filteredEvents.map((event) => ({
							title: event.title,
							appUrl: event.appUrl
						}))
					}),
					faqPageJsonLd([...page.faq]),
					breadcrumbJsonLd(getLandingBreadcrumbs(page))
				]
			}
		};
	});
}

const { page, events, unavailable, sceneStats, seo, canonicalPath, jsonLd } = Astro.props;
---

<EventLandingPage
	{page}
	{events}
	{unavailable}
	{sceneStats}
	{seo}
	{canonicalPath}
	{jsonLd}
/>
