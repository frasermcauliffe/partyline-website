---
import { formatBlogDate, shouldShowUpdatedDate } from '@/lib/blog';

interface Props {
	category?: string;
	publishedAt: Date;
	updatedAt?: Date;
	author: string;
	showUpdated?: boolean;
}

const { category, publishedAt, updatedAt, author, showUpdated = false }: Props = Astro.props;

const showUpdateLine = showUpdated && shouldShowUpdatedDate(publishedAt, updatedAt);
---

<div class="post-meta">
	{
		category && (
			<span class="post-meta__category">{category}</span>
		)
	}
	<time datetime={publishedAt.toISOString()}>{formatBlogDate(publishedAt)}</time>
	<span class="post-meta__author">{author}</span>
	{
		showUpdateLine && updatedAt && (
			<span class="post-meta__updated">
				Updated <time datetime={updatedAt.toISOString()}>{formatBlogDate(updatedAt)}</time>
			</span>
		)
	}
</div>

<style>
	.post-meta {
		align-items: center;
		color: var(--color-muted);
		display: flex;
		flex-wrap: wrap;
		font-family: var(--font-label);
		font-size: 0.75rem;
		gap: var(--space-2) var(--space-3);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.post-meta__category {
		color: var(--color-primary);
	}

	.post-meta__author {
		font-family: var(--font-body);
		letter-spacing: normal;
		text-transform: none;
	}

	.post-meta__author::before,
	.post-meta__updated::before {
		color: var(--color-border);
		content: '·';
		margin-right: var(--space-3);
	}

	.post-meta__author::before {
		margin-left: 0;
	}
</style>
