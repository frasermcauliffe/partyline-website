---
import ContentCard from '@/components/ui/ContentCard.astro';
import ImagePlaceholder from '@/components/ui/ImagePlaceholder.astro';
import { cleanBlogText, formatBlogDate, getPostSlug, readingTimeLabel, type BlogEntry } from '@/lib/blog';

interface Props {
	post: BlogEntry;
}

const { post } = Astro.props;
const { title, description, category, publishedAt, featuredImage, featuredImageAlt } = post.data;
const slug = getPostSlug(post);
const href = `/blog/${slug}`;
const cleanCategory = category ? cleanBlogText(category) : undefined;
const readTime = readingTimeLabel(post.body);

const meta = [
	...(cleanCategory ? [{ label: cleanCategory, accent: true }] : []),
	{ label: formatBlogDate(publishedAt) },
	...(readTime ? [{ label: readTime }] : [])
];
---

<ContentCard
	href={href}
	title={title}
	description={cleanBlogText(description)}
	meta={meta}
	linkLabel="Read article →"
>
	<Fragment slot="media">
		{
			featuredImage ? (
				<img src={featuredImage} alt={featuredImageAlt ?? ''} loading="lazy" decoding="async" />
			) : (
				<ImagePlaceholder aspectRatio="16 / 9" />
			)
		}
	</Fragment>
</ContentCard>
