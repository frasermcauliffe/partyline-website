---
import { cleanBlogText, formatBlogDate, getPostSlug, type BlogEntry } from '@/lib/blog';

interface Props {
	post: BlogEntry;
}

const { post } = Astro.props;
const { title, description, category, publishedAt, featuredImage, featuredImageAlt } = post.data;
const slug = getPostSlug(post);
const href = `/blog/${slug}`;
const cleanDescription = cleanBlogText(description);
const cleanCategory = category ? cleanBlogText(category) : undefined;
---

<article class="blog-card">
	{
		featuredImage && (
			<a href={href} class="blog-card__media" tabindex="-1" aria-hidden="true">
				<img src={featuredImage} alt={featuredImageAlt ?? ''} loading="lazy" decoding="async" />
			</a>
		)
	}
	<div class="blog-card__body">
		<p class="blog-card__meta">
			{cleanCategory && <span class="blog-card__category">{cleanCategory}</span>}
			<time datetime={publishedAt.toISOString()}>{formatBlogDate(publishedAt)}</time>
		</p>
		<h2 class="blog-card__title">
			<a href={href}>{title}</a>
		</h2>
		<p class="blog-card__description">{cleanDescription}</p>
		<a href={href} class="blog-card__link">
			Read article →
		</a>
	</div>
</article>

<style>
	.blog-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		display: grid;
		height: 100%;
		min-width: 0;
		overflow: hidden;
		transition:
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.blog-card:hover,
	.blog-card:focus-within {
		border-color: var(--color-primary);
		transform: translateY(-2px);
	}

	.blog-card__media {
		aspect-ratio: 16 / 9;
		background: var(--color-surface-soft);
		display: block;
		overflow: hidden;
	}

	.blog-card__media img {
		height: 100%;
		object-fit: cover;
		object-position: top center;
		width: 100%;
	}

	.blog-card__body {
		display: grid;
		gap: var(--space-3);
		padding: var(--space-5);
	}

	.blog-card__meta {
		align-items: center;
		color: var(--color-muted);
		display: flex;
		flex-wrap: wrap;
		font-family: var(--font-label);
		font-size: 0.7rem;
		gap: var(--space-2) var(--space-3);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.blog-card__category {
		color: var(--color-primary);
	}

	.blog-card__title {
		font-size: 1.1rem;
		line-height: 1.35;
		overflow-wrap: anywhere;
	}

	.blog-card__title a {
		color: inherit;
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		text-decoration: none;
	}

	.blog-card__title a:hover,
	.blog-card__title a:focus-visible {
		color: var(--color-primary);
	}

	.blog-card__description {
		color: var(--color-muted);
		display: -webkit-box;
		font-size: 0.95rem;
		line-height: 1.55;
		overflow-wrap: anywhere;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
	}

	.blog-card__link {
		color: var(--color-primary);
		font-size: 0.9rem;
		font-weight: 600;
		margin-top: auto;
		text-decoration: none;
		width: fit-content;
	}

	.blog-card__link:hover,
	.blog-card__link:focus-visible {
		text-decoration: underline;
	}
</style>
