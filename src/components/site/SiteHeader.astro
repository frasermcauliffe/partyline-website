---
import Button from '@/components/ui/Button.astro';
import { APP_LINKS } from '@/data/app-links';
import { desktopNav, mobileNavGroups, mobileNavJoinItem } from '@/data/nav';

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<div class="container site-header__bar">
		<a href="/" class="brand" aria-label="PartyLine Collective home">
			<img
				src="/partyline-logo-header.png"
				alt="PartyLine Collective"
				class="brand__logo"
				width="206"
				height="61"
				decoding="async"
			/>
		</a>

		<nav class="site-nav" aria-label="Main navigation">
			<ul class="site-nav__list">
				{
					desktopNav.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={['site-nav__link', currentPath === item.href && 'is-active']}
								{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>

			<details class="site-nav__mobile">
				<summary class="site-nav__summary">
					<span>Menu</span>
					<svg
						class="site-nav__chevron"
						viewBox="0 0 16 16"
						width="16"
						height="16"
						aria-hidden="true"
						focusable="false"
					>
						<path
							d="M4 6l4 4 4-4"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</summary>

				<div class="site-nav__panel">
					{
						mobileNavGroups.map((group) => (
							<div class="site-nav__group">
								<p class="site-nav__group-label">{group.label}</p>
								<ul class="site-nav__group-list">
									{group.items.map((item) => (
										<li>
											<a
												href={item.href}
												class:list={[
													'site-nav__mobile-link',
													currentPath === item.href && 'is-active'
												]}
												{...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
											>
												{item.label}
											</a>
										</li>
									))}
								</ul>
							</div>
						))
					}
					<div class="site-nav__mobile-cta">
						<a
							href={mobileNavJoinItem.href}
							class="site-nav__mobile-join"
							target="_blank"
							rel="noopener noreferrer"
						>
							{mobileNavJoinItem.label}
						</a>
					</div>
				</div>
			</details>
		</nav>

		<div class="site-header__actions">
			<Button
				href={APP_LINKS.joinSignup}
				label="Join PartyLine"
				variant="primary"
				external
				class="site-header__join"
			/>
		</div>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid var(--color-border);
		padding-block: var(--space-2);
		position: sticky;
		top: 0;
		z-index: var(--z-header);
		background: rgba(5, 5, 5, 0.92);
		backdrop-filter: blur(8px);
	}

	.site-header__bar {
		align-items: center;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-3);
		justify-content: space-between;
	}

	.brand {
		display: inline-flex;
		flex-shrink: 0;
		line-height: 0;
		text-decoration: none;
	}

	.brand__logo {
		height: 32px;
		max-width: min(11rem, 46vw);
		object-fit: contain;
		width: auto;
	}

	.site-nav {
		flex: 1 1 100%;
		min-width: 0;
		order: 3;
	}

	/* Desktop inline list — hidden on mobile (replaced by the disclosure menu). */
	.site-nav__list {
		display: none;
	}

	.site-nav__link {
		align-items: center;
		border: 1px solid transparent;
		border-radius: var(--radius-pill);
		color: var(--color-muted);
		display: inline-flex;
		flex-shrink: 0;
		font-size: 0.8rem;
		min-height: 2.5rem;
		padding: 0.35rem 0.65rem;
		text-decoration: none;
		white-space: nowrap;
	}

	.site-nav__link:hover,
	.site-nav__link:focus-visible,
	.site-nav__link.is-active {
		border-color: var(--color-border);
		color: var(--color-text);
	}

	.site-nav__link.is-active {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	/* Mobile disclosure menu (no JS). */
	.site-nav__mobile {
		width: 100%;
	}

	.site-nav__summary {
		align-items: center;
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-pill);
		color: var(--color-muted-strong);
		cursor: pointer;
		display: flex;
		font-family: var(--font-label);
		font-size: 0.8rem;
		gap: var(--space-2);
		justify-content: center;
		letter-spacing: var(--tracking-label);
		list-style: none;
		min-height: 2.75rem;
		padding: 0.45rem 1rem;
		text-transform: uppercase;
		user-select: none;
	}

	.site-nav__summary::-webkit-details-marker {
		display: none;
	}

	.site-nav__summary:hover,
	.site-nav__summary:focus-visible {
		border-color: var(--color-primary);
		color: var(--color-text);
	}

	.site-nav__chevron {
		transition: transform var(--duration-base) var(--ease-out);
	}

	.site-nav__mobile[open] .site-nav__chevron {
		transform: rotate(180deg);
	}

	.site-nav__panel {
		display: grid;
		gap: var(--space-5);
		padding-block: var(--space-4) var(--space-2);
	}

	.site-nav__group-label {
		color: var(--color-muted);
		font-family: var(--font-label);
		font-size: var(--text-meta);
		letter-spacing: var(--tracking-label);
		margin-bottom: var(--space-2);
		text-transform: uppercase;
	}

	.site-nav__group-list {
		display: grid;
		gap: var(--space-1);
		list-style: none;
	}

	.site-nav__mobile-link {
		border-radius: var(--radius-sm);
		color: var(--color-muted-strong);
		display: block;
		min-height: 2.75rem;
		padding: 0.6rem 0.75rem;
		text-decoration: none;
	}

	.site-nav__mobile-link:hover,
	.site-nav__mobile-link:focus-visible {
		background: var(--surface-2);
		color: var(--color-text);
	}

	.site-nav__mobile-link.is-active {
		color: var(--color-primary);
	}

	.site-nav__mobile-cta {
		border-top: 1px solid var(--border-subtle);
		margin-top: var(--space-2);
		padding-top: var(--space-4);
	}

	.site-nav__mobile-join {
		align-items: center;
		background: var(--color-primary);
		border-radius: var(--radius-pill);
		color: var(--color-bg);
		display: inline-flex;
		font-size: 0.875rem;
		font-weight: var(--weight-semibold);
		justify-content: center;
		min-height: 2.5rem;
		padding: 0.4rem 1rem;
		text-decoration: none;
		width: 100%;
	}

	.site-nav__mobile-join:hover,
	.site-nav__mobile-join:focus-visible {
		filter: brightness(1.05);
	}

	.site-header__actions {
		align-items: center;
		display: flex;
		flex-shrink: 0;
		margin-left: auto;
	}

	.site-header__actions :global(.site-header__join) {
		min-height: 2.25rem;
		padding: 0.4rem 0.9rem;
	}

	@media (min-width: 960px) {
		.site-nav {
			flex: 1;
			order: 0;
		}

		.site-header__bar {
			flex-wrap: nowrap;
			gap: var(--space-2);
		}

		.brand__logo {
			height: 36px;
		}

		.site-nav__list {
			display: flex;
			flex-wrap: nowrap;
			gap: 0.125rem;
			list-style: none;
			justify-content: flex-end;
		}

		.site-nav__link {
			font-size: 0.875rem;
			padding: 0.35rem 0.65rem;
		}

		/* Disclosure menu is mobile-only. */
		.site-nav__mobile {
			display: none;
		}
	}

	@media (min-width: 960px) and (max-width: 1100px) {
		.site-nav__link {
			font-size: 0.8125rem;
			min-height: 2.35rem;
			padding: 0.3rem 0.5rem;
		}

		.site-header__actions :global(.site-header__join) {
			font-size: 0.8125rem;
			min-height: 2.15rem;
			padding: 0.35rem 0.75rem;
		}
	}
</style>
