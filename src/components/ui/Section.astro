---
interface Props {
	narrow?: boolean;
	class?: string;
}

const { narrow = false, class: className = '' }: Props = Astro.props;
---

<section class:list={['section', narrow && 'section--narrow', className]}>
	<div class="container" class:list={[narrow && 'container--narrow']}>
		<slot />
	</div>
</section>

<style>
	.section {
		padding-block: var(--section-gap);
	}

	.section--narrow {
		padding-block: clamp(2rem, 6vw, 3rem);
	}
</style>
