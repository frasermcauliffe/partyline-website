---
/**
 * RelatedLinks — unified related-links block.
 *
 * W10b: created as a foundation only. Existing related-link patterns (guide
 * "Explore PartyLine" list, page `.related-links`) are NOT migrated yet.
 */
interface RelatedLink {
	label: string;
	href: string;
	external?: boolean;
}

interface Props {
	title?: string;
	links: RelatedLink[];
	layout?: 'list' | 'inline';
	class?: string;
}

const {
	title = 'Explore PartyLine',
	links,
	layout = 'list',
	class: className = ''
}: Props = Astro.props;
---

<nav class:list={['related-links', `related-links--${layout}`, className]} aria-label={title}>
	{title && <h2 class="related-links__title">{title}</h2>}
	<ul class="related-links__list">
		{
			links.map((link) => (
				<li>
					<a
						href={link.href}
						{...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
					>
						{link.label}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.related-links {
		border-top: 1px solid var(--border-subtle);
		padding-top: var(--space-5);
	}

	.related-links__title {
		font-size: var(--text-card-title);
		margin-bottom: var(--space-4);
	}

	.related-links__list {
		display: grid;
		gap: var(--space-2);
		list-style: none;
	}

	.related-links--inline .related-links__list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3) var(--space-5);
	}

	.related-links__list a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.related-links__list a:hover,
	.related-links__list a:focus-visible {
		text-decoration: underline;
	}
</style>
