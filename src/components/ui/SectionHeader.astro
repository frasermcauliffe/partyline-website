---
interface Props {
	eyebrow?: string;
	title: string;
	lede?: string;
	align?: 'start' | 'center';
}

const { eyebrow, title, lede, align = 'start' }: Props = Astro.props;
---

<header class:list={['section-header', align === 'center' && 'section-header--center']}>
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2>{title}</h2>
	{lede && <p class="lede">{lede}</p>}
</header>

<style>
	.section-header {
		margin-bottom: clamp(1.5rem, 4vw, 2rem);
		max-width: 42rem;
	}

	.section-header--center {
		margin-inline: auto;
		text-align: center;
	}

	.section-header--center .lede {
		margin-inline: auto;
	}

	h2 {
		font-size: clamp(1.5rem, 4vw, 2rem);
	}
</style>
