---
interface Props {
	title: string;
	description?: string;
	href?: string;
	external?: boolean;
	class?: string;
}

const { title, description, href, external = false, class: className = '' }: Props = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
	href={href}
	class:list={['card', href && 'card--link', className]}
	{...(href && external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
	<h3>{title}</h3>
	{description && <p>{description}</p>}
	<slot />
</Tag>

<style>
	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		display: grid;
		gap: var(--space-3);
		min-width: 0;
		padding: var(--space-5);
	}

	.card--link {
		color: inherit;
		text-decoration: none;
		transition:
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.card--link:hover,
	.card--link:focus-visible {
		border-color: var(--color-primary);
		transform: translateY(-2px);
	}

	h3 {
		font-size: 1.05rem;
	}

	p {
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}
</style>
