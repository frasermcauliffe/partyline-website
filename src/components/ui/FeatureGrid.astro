---
interface FeatureItem {
	title: string;
	description: string;
}

interface Props {
	items: FeatureItem[];
	columns?: 2 | 3;
}

const { items, columns = 3 }: Props = Astro.props;
---

<ul class:list={['feature-grid', `feature-grid--${columns}`]}>
	{
		items.map((item) => (
			<li class="feature-grid__item">
				<h3>{item.title}</h3>
				<p>{item.description}</p>
			</li>
		))
	}
</ul>

<style>
	.feature-grid {
		display: grid;
		gap: var(--space-4);
		list-style: none;
	}

	.feature-grid--2 {
		grid-template-columns: 1fr;
	}

	.feature-grid--3 {
		grid-template-columns: 1fr;
	}

	@media (min-width: 640px) {
		.feature-grid--2 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.feature-grid--3 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 960px) {
		.feature-grid--3 {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.feature-grid__item {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		min-width: 0;
		padding: var(--space-5);
	}

	.feature-grid__item h3 {
		font-size: 1rem;
		margin-bottom: var(--space-2);
	}

	.feature-grid__item p {
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}
</style>
