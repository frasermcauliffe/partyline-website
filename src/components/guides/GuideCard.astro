---
import ContentCard from '@/components/ui/ContentCard.astro';
import { cleanBlogText, formatBlogDate, readingTimeLabel } from '@/lib/blog';
import { formatGuideAudience, guideHref, type GuideEntry } from '@/lib/guides';

interface Props {
	guide: GuideEntry;
}

const { guide } = Astro.props;
const { title, description, category, audience, publishedAt } = guide.data;
const href = guideHref(guide);
const readTime = readingTimeLabel(guide.body);

const meta = [
	{ label: cleanBlogText(category), accent: true },
	{ label: formatGuideAudience(audience), plain: true },
	{ label: formatBlogDate(publishedAt) },
	...(readTime ? [{ label: readTime }] : [])
];
---

<ContentCard
	href={href}
	title={title}
	description={cleanBlogText(description)}
	meta={meta}
	linkLabel="Read guide →"
/>
