---
import Button from '@/components/ui/Button.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import type { HomeSceneProfileCard } from '@/data/home-content';
import { APP_LINKS } from '@/data/app-links';

interface Props {
	profiles: HomeSceneProfileCard[];
}

const { profiles }: Props = Astro.props;
---

<div class="scene-profiles">
	<div class="scene-profiles__grid">
		{
			profiles.map((profile) => (
				<PremiumCard variant="preview" class="scene-profile-card">
					<p class="scene-profile-card__meta">
						{profile.type} · {profile.city}
					</p>
					<h3>{profile.name}</h3>
					<p class="scene-profile-card__tags">{profile.tags}</p>
					<p class="scene-profile-card__description">{profile.description}</p>
				</PremiumCard>
			))
		}
	</div>
	<p class="scene-profiles__note">
		Example profile types shown for layout preview. Browse live public listings in the app.
	</p>
	<div class="scene-profiles__actions">
		<Button href={APP_LINKS.theScene} label="Browse profiles in the app" variant="primary" external />
		<Button href={APP_LINKS.createListing} label="Create profile" variant="secondary" external />
	</div>
</div>

<style>
	.scene-profiles {
		display: grid;
		gap: var(--space-5);
	}

	.scene-profiles__grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.scene-profiles__grid :global(.scene-profile-card h3) {
		font-size: var(--text-card-title);
		line-height: 1.35;
	}

	.scene-profile-card__meta,
	.scene-profile-card__tags {
		color: var(--color-muted);
		font-family: var(--font-label);
		font-size: var(--text-meta);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.scene-profile-card__description {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
	}

	.scene-profiles__note {
		color: var(--color-muted);
		font-size: var(--text-small);
		line-height: 1.55;
		max-width: 42rem;
	}

	.scene-profiles__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	@media (min-width: 640px) {
		.scene-profiles__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.scene-profiles__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
