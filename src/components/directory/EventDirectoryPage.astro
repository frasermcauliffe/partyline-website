---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import SectionShell from '@/components/ui/SectionShell.astro';
import PremiumCard from '@/components/ui/PremiumCard.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import FaqList from '@/components/ui/FaqList.astro';
import PreviewPanel from '@/components/previews/PreviewPanel.astro';
import PublicEventPreviewCard from '@/components/previews/PublicEventPreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import DirectoryFormatsStrip from '@/components/directory/DirectoryFormatsStrip.astro';
import DirectoryHero from '@/components/directory/DirectoryHero.astro';
import DirectoryStatsRow from '@/components/directory/DirectoryStatsRow.astro';
import DirectoryFilterChips from '@/components/directory/DirectoryFilterChips.astro';
import DirectorySceneSnapshot from '@/components/directory/DirectorySceneSnapshot.astro';
import EventLocationMap from '@/components/directory/EventLocationMap.astro';
import { APP_LINKS } from '@/data/app-links';
import {
	DIRECTORY_FAQ,
	DIRECTORY_FILTER_CHIPS,
	DIRECTORY_GENRES,
	DIRECTORY_SOURCING,
	type DirectoryGenreEntry
} from '@/data/directory-content';
import {
	formatDirectoryGenreBadge,
	type DirectoryStats,
	type SceneSnapshotCard,
	type TrackedEventFormatsResult
} from '@/lib/event-directory-stats';
import { SCENE_SNAPSHOT_HEADING } from '@/lib/event-landing-data';
import type { PublicEventPreview } from '@/lib/app-preview-types';
import type { PublicSceneIndexFetchResult } from '@/lib/public-scene-index';
import type { PageSeo } from '@/lib/seo';

interface Props {
	seo: PageSeo;
	jsonLd: string[];
	events: PublicEventPreview[];
	eventsUnavailable: boolean;
	stats: DirectoryStats;
	trackedFormats: TrackedEventFormatsResult | null;
	sceneSnapshot: SceneSnapshotCard[];
	sceneResult: PublicSceneIndexFetchResult;
}

const {
	seo,
	jsonLd,
	events,
	eventsUnavailable,
	stats,
	trackedFormats,
	sceneSnapshot,
	sceneResult
}: Props = Astro.props;

function genreBadge(
	entry: DirectoryGenreEntry,
	previewEvents: PublicEventPreview[]
): string | undefined {
	return formatDirectoryGenreBadge(entry, previewEvents, sceneResult);
}
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	canonicalPath={seo.canonicalPath}
	jsonLd={jsonLd}
>
	<DirectoryHero />

	<SectionShell variant="inset" eyebrow={SCENE_SNAPSHOT_HEADING} title="Current listings snapshot">
		<DirectoryStatsRow stats={stats} />
	</SectionShell>

	{trackedFormats && <DirectoryFormatsStrip formatsResult={trackedFormats} />}

	<SectionShell eyebrow="Quick filters" title="Browse upcoming events">
		<DirectoryFilterChips chips={DIRECTORY_FILTER_CHIPS} />
	</SectionShell>

	<PreviewPanel
		eyebrow="Directory"
		title="Upcoming events"
		lede="Public preview below — sample of upcoming listings from the PartyLine app. Perth-first, building across Australia. Open the app for posters, lineups, filters and full details."
		source="app"
		ctaLabel="Explore all events in the app"
		ctaHref={APP_LINKS.events}
		narrow={false}
	>
		{
			events.length > 0 ? (
				<div class="directory-events-grid">
					{events.map((event) => (
						<PublicEventPreviewCard event={event} />
					))}
				</div>
			) : (
				<EmptyPreviewState
					ctaHref={APP_LINKS.submitEvent}
					unavailable={eventsUnavailable}
					message="No upcoming public events are in the current preview. Submit your event or explore the app for the latest listings."
					ctaLabel="Submit Event"
				/>
			)
		}
		{
			events.length === 0 && (
				<p class="directory-empty-secondary">
					<a href={APP_LINKS.events} target="_blank" rel="noopener noreferrer">
						Explore events in the app &rarr;
					</a>
				</p>
			)
		}
	</PreviewPanel>

	<SectionShell
		variant="band"
		eyebrow="Location"
		title="Search by location"
		lede="Explore underground events by city — click a marker or choose a city below."
	>
		<EventLocationMap sceneResult={sceneResult} previewEvents={events} />
	</SectionShell>

	<SectionShell
		eyebrow="Genres"
		title="Browse by genre"
		lede="Genre landing pages link to the closest app filters. More tags are added as organisers submit events."
	>
		<div class="directory-browse-grid directory-browse-grid--genres">
			{
				DIRECTORY_GENRES.map((genre) => {
					const badge = genreBadge(genre, events);
					return (
						<PremiumCard
							variant="quiet"
							href={genre.href}
							external={genre.external}
							class="directory-browse-card"
						>
							{badge && <p class="directory-browse-card__badge">{badge}</p>}
							<h3>{genre.name}</h3>
							<p class="directory-browse-card__link">
								{genre.external ? 'Browse in app' : 'Browse events'} &rarr;
							</p>
						</PremiumCard>
					);
				})
			}
		</div>
	</SectionShell>

	<SectionShell variant="feature" eyebrow={SCENE_SNAPSHOT_HEADING} title="Snapshot detail">
		<DirectorySceneSnapshot cards={sceneSnapshot} />
	</SectionShell>

	<SectionShell
		variant="inset"
		eyebrow="Sourcing"
		title="How events are listed"
		lede="Honest sourcing for the PartyLine Event Directory during alpha — no scraping and no automated ticketing imports."
	>
		<FeatureGrid items={[...DIRECTORY_SOURCING]} columns={2} />
	</SectionShell>

	<SectionShell eyebrow="FAQ" title="Event directory questions">
		<FaqList items={[...DIRECTORY_FAQ]} />
	</SectionShell>

	<section class="directory-final-cta">
		<div class="container directory-final-cta__inner">
			<div class="directory-final-cta__copy">
				<h2>Put your event on the line.</h2>
				<p>
					Submit your night, explore what&rsquo;s on, or create a profile — Perth-first, building
					across Australia.
				</p>
			</div>
			<div class="directory-final-cta__actions">
				<Button href={APP_LINKS.submitEvent} label="Submit Event" variant="primary" external />
				<Button href={APP_LINKS.events} label="Explore Events" variant="secondary" external />
				<Button href={APP_LINKS.createListing} label="Create Profile" variant="secondary" external />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.directory-events-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
	}

	.directory-empty-secondary {
		margin-top: var(--space-4);
		text-align: center;
	}

	.directory-empty-secondary a {
		color: var(--signal);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.directory-empty-secondary a:hover,
	.directory-empty-secondary a:focus-visible {
		text-decoration: underline;
	}

	.directory-browse-grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
	}

	.directory-browse-grid :global(.directory-browse-card h3) {
		font-size: var(--text-card-title);
		line-height: 1.35;
	}

	.directory-browse-card__badge {
		color: var(--signal);
		font-family: var(--font-label);
		font-size: var(--text-meta);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.directory-browse-card__link {
		color: var(--color-muted);
		font-size: var(--text-small);
	}

	.directory-final-cta {
		background: linear-gradient(
			180deg,
			var(--color-surface-soft) 0%,
			rgba(60, 232, 97, 0.06) 100%
		);
		border-block: 1px solid var(--color-border);
		padding-block: clamp(2.5rem, 7vw, 4rem);
	}

	.directory-final-cta__inner {
		align-items: center;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		text-align: center;
	}

	.directory-final-cta__copy {
		display: grid;
		gap: var(--space-3);
		max-width: 38rem;
	}

	.directory-final-cta__copy h2 {
		font-size: clamp(1.5rem, 4vw, 2rem);
	}

	.directory-final-cta__copy p {
		color: var(--color-muted-strong);
		line-height: 1.6;
	}

	.directory-final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		justify-content: center;
	}

	@media (min-width: 640px) {
		.directory-events-grid,
		.directory-browse-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.directory-browse-grid--genres {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.directory-final-cta__inner {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}

		.directory-final-cta__actions {
			flex-shrink: 0;
			justify-content: flex-end;
		}
	}

	@media (min-width: 1024px) {
		.directory-events-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.directory-browse-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}

		.directory-browse-grid--genres {
			grid-template-columns: repeat(5, minmax(0, 1fr));
		}
	}
</style>
