---
import Button from '@/components/ui/Button.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import PublicEventPreviewCard from '@/components/previews/PublicEventPreviewCard.astro';
import EmptyPreviewState from '@/components/previews/EmptyPreviewState.astro';
import type { PublicEventPreview } from '@/lib/app-preview-types';

interface Props {
	eyebrow?: string;
	title: string;
	lede?: string;
	events: PublicEventPreview[];
	unavailable?: boolean;
	ctaLabel?: string;
	ctaHref: string;
	narrow?: boolean;
}

const {
	eyebrow,
	title,
	lede,
	events,
	unavailable = false,
	ctaLabel = 'Explore events in the app',
	ctaHref,
	narrow = true
} = Astro.props;
---

<Section narrow={narrow}>
	<SectionHeader eyebrow={eyebrow} title={title} lede={lede} />
	{
		events.length > 0 ? (
			<>
				<div class="event-preview-grid">
					{events.map((event) => (
						<PublicEventPreviewCard event={event} />
					))}
				</div>
				<div class="event-preview-actions">
					<Button href={ctaHref} label={ctaLabel} variant="secondary" external />
				</div>
			</>
		) : (
			<EmptyPreviewState ctaHref={ctaHref} unavailable={unavailable} />
		)
	}
</Section>

<style>
	.event-preview-grid {
		align-items: stretch;
		display: grid;
		gap: var(--space-5);
		grid-template-columns: 1fr;
		margin-bottom: var(--space-5);
	}

	@media (min-width: 640px) {
		.event-preview-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.event-preview-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.event-preview-actions {
		display: flex;
		justify-content: center;
	}
</style>
