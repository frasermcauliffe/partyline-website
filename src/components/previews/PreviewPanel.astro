---
/**
 * PreviewPanel — frame for app-sourced live preview sections.
 *
 * W10b: created as a foundation only. The existing live preview sections
 * (events / profiles / opportunities) are NOT wrapped yet — that happens in
 * W10d. This component frames a slot of preview content as app-sourced data
 * with an optional source label and CTA.
 */
import Button from '@/components/ui/Button.astro';

interface Props {
	eyebrow?: string;
	title: string;
	lede?: string;
	source?: 'app';
	ctaLabel?: string;
	ctaHref?: string;
	external?: boolean;
	narrow?: boolean;
	class?: string;
}

const {
	eyebrow,
	title,
	lede,
	source,
	ctaLabel,
	ctaHref,
	external = true,
	narrow = true,
	class: className = ''
}: Props = Astro.props;

const hasCta = Boolean(ctaLabel && ctaHref);
---

<section class:list={['preview-panel', className]}>
	<div class="container" class:list={[narrow && 'container--narrow']}>
		<div class="preview-panel__frame">
			<header class="preview-panel__header">
				<div class="preview-panel__heading">
					{eyebrow && <p class="eyebrow">{eyebrow}</p>}
					<h2>{title}</h2>
					{lede && <p class="lede">{lede}</p>}
				</div>
				{
					source === 'app' && (
						<p class="preview-panel__source">
							<span class="preview-panel__dot" aria-hidden="true" />
							Live from the app
						</p>
					)
				}
			</header>

			<div class="preview-panel__body">
				<slot />
			</div>

			{
				hasCta && (
					<div class="preview-panel__actions">
						<Button href={ctaHref!} label={ctaLabel!} variant="secondary" external={external} />
					</div>
				)
			}
		</div>
	</div>
</section>

<style>
	.preview-panel {
		padding-block: var(--section-gap);
	}

	.preview-panel__frame {
		background: var(--surface-1);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-panel);
		padding: clamp(1.5rem, 5vw, 2.5rem);
	}

	.preview-panel__header {
		align-items: start;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3) var(--space-5);
		justify-content: space-between;
		margin-bottom: clamp(1.5rem, 4vw, 2rem);
	}

	.preview-panel__heading {
		max-width: 42rem;
	}

	.preview-panel__heading h2 {
		font-size: var(--text-h2);
	}

	.preview-panel__source {
		align-items: center;
		color: var(--signal);
		display: inline-flex;
		flex-shrink: 0;
		font-family: var(--font-label);
		font-size: var(--text-meta);
		gap: var(--space-2);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.preview-panel__dot {
		background: var(--signal);
		border-radius: var(--radius-pill);
		height: 0.5rem;
		width: 0.5rem;
	}

	.preview-panel__actions {
		display: flex;
		justify-content: center;
		margin-top: var(--space-6);
	}
</style>
