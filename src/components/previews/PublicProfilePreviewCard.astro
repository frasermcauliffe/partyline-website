---
import type { PublicListingPreview } from '@/lib/app-preview-types';
import { profileUrl } from '@/data/app-links';

interface Props {
	profile: PublicListingPreview;
}

const { profile } = Astro.props;
const href = profileUrl(profile.slug);
const tagLabel = profile.tags.slice(0, 4).join(' · ');
const metaParts = [profile.profileType, profile.city].filter(Boolean);
const venueMeta = [profile.venueType, profile.capacity].filter(Boolean).join(' · ');
---

<article class="profile-preview-card">
	{
		profile.imageUrl && (
			<a
				href={href}
				class="profile-preview-card__media"
				target="_blank"
				rel="noopener noreferrer"
				tabindex="-1"
				aria-hidden="true"
			>
				<img
					src={profile.imageUrl}
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</a>
		)
	}
	<div class="profile-preview-card__body">
		<p class="profile-preview-card__meta">
			{metaParts.length > 0 && <span>{metaParts.join(' · ')}</span>}
		</p>
		<h2 class="profile-preview-card__title">
			<a href={href} target="_blank" rel="noopener noreferrer">
				{profile.name}
			</a>
		</h2>
		{
			venueMeta && (
				<p class="profile-preview-card__venue-meta">{venueMeta}</p>
			)
		}
		{
			profile.shortDescription && (
				<p class="profile-preview-card__description">{profile.shortDescription}</p>
			)
		}
		{
			tagLabel && (
				<p class="profile-preview-card__tags">{tagLabel}</p>
			)
		}
		<a href={href} class="profile-preview-card__link" target="_blank" rel="noopener noreferrer">
			View in app →
		</a>
	</div>
</article>

<style>
	.profile-preview-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		display: grid;
		height: 100%;
		min-width: 0;
		overflow: hidden;
		transition:
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.profile-preview-card:hover,
	.profile-preview-card:focus-within {
		border-color: var(--color-primary);
		transform: translateY(-2px);
	}

	.profile-preview-card__media {
		aspect-ratio: 1;
		background: var(--color-surface-soft);
		display: block;
		overflow: hidden;
	}

	.profile-preview-card__media img {
		height: 100%;
		object-fit: cover;
		object-position: top center;
		width: 100%;
	}

	.profile-preview-card__body {
		display: grid;
		gap: var(--space-3);
		padding: var(--space-5);
	}

	.profile-preview-card__meta {
		color: var(--color-muted);
		font-family: var(--font-label);
		font-size: 0.7rem;
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	.profile-preview-card__title {
		font-size: 1.1rem;
		line-height: 1.35;
		overflow-wrap: anywhere;
	}

	.profile-preview-card__title a {
		color: inherit;
		display: -webkit-box;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		text-decoration: none;
	}

	.profile-preview-card__title a:hover,
	.profile-preview-card__title a:focus-visible {
		color: var(--color-primary);
	}

	.profile-preview-card__venue-meta,
	.profile-preview-card__description,
	.profile-preview-card__tags {
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.5;
		overflow-wrap: anywhere;
	}

	.profile-preview-card__tags {
		font-size: 0.85rem;
	}

	.profile-preview-card__link {
		color: var(--color-primary);
		font-size: 0.9rem;
		font-weight: 600;
		margin-top: auto;
		text-decoration: none;
		width: fit-content;
	}

	.profile-preview-card__link:hover,
	.profile-preview-card__link:focus-visible {
		text-decoration: underline;
	}
</style>
