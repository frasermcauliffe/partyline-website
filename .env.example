# PartyLine marketing site — environment variables
#
# Copy to .env for local overrides (optional).

# Base URL for the SvelteKit app public API (no trailing slash).
# Defaults to APP_URL in src/data/app-links.ts when unset.
# Local dev example (SvelteKit on port 5173):
# PUBLIC_APP_API_URL=http://localhost:5173
#
# Preview/production example:
# PUBLIC_APP_API_URL=https://partyline-webapp.vercel.app
