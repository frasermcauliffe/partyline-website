# PartyLine marketing site — environment variables
#
# Copy to .env for local overrides (optional).

# SvelteKit app origin for CTAs and preview card links (no trailing slash).
# When unset, falls back to the hosted preview app.
# PUBLIC_APP_URL=https://app.partylinecollective.com

# Base URL for the SvelteKit app public API at build time (no trailing slash).
# When unset, falls back to PUBLIC_APP_URL (or the preview app fallback).
# Local dev example (SvelteKit on port 5173):
# PUBLIC_APP_API_URL=http://localhost:5173
#
# Production cutover (set both in Vercel before redeploying the website):
# PUBLIC_APP_URL=https://app.partylinecollective.com
# PUBLIC_APP_API_URL=https://app.partylinecollective.com
